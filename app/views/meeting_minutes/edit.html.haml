= turbo_frame_tag "meeting_form_modal" do
  .fixed.inset-0.bg-black.bg-opacity-50.z-50{ data: { controller: "modal" } }
    .fixed.inset-0.flex.items-center.justify-center.p-4.pb-20.lg:pb-4
      .bg-white.rounded-lg.shadow-xl.max-w-4xl.w-full{ 
        style: "max-height: calc(100vh - 2rem); overflow-y: auto;",
        data: { modal_target: "content" } 
      }
        .bg-green-50.px-6.py-4.border-b
          .flex.items-center.justify-between
            %h2.text-xl.font-semibold.text-gray-800
              %i.fas.fa-edit.text-green-500.mr-2
              会議議事録を編集
            = link_to meeting_minute_path(@meeting_minute), class: "text-gray-500 hover:text-gray-700", data: { turbo_frame: "_top" } do
              %i.fas.fa-times

        = form_with model: @meeting_minute, local: false, class: "px-6 py-6", data: { controller: "file-upload", file_upload_meeting_id_value: @meeting_minute.id, session_id: session.id } do |form|
          - if @meeting_minute.errors.any?
            .mb-6.bg-red-50.border.border-red-200.rounded-lg.p-4
              %h3.text-sm.font-medium.text-red-800.mb-2
                入力内容に問題があります：
              %ul.text-sm.text-red-700.space-y-1
                - @meeting_minute.errors.full_messages.each do |message|
                  %li= message

          .space-y-6
            / 会議名
            %div
              = form.label :title, "会議名", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
              = form.text_field :title, 
                  class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

            / 会議種別
            %div
              = form.label :meeting_type, "会議種別", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
              = form.select :meeting_type, options_for_select([['利用者支援会議', 'support_meeting'], ['専門職団体会議', 'professional_meeting']], @meeting_minute.meeting_type), {}, { class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors" }

            / プロンプトテンプレート選択
            %div
              = form.label :prompt_template_id, "AIプロンプト設定", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
              %span.text-xs.text-slate-500 (音声・画像からの議事録生成時に使用)
              %br
              = form.select :prompt_template_id, 
                  options_from_collection_for_select(@prompt_templates, :id, :display_name, @meeting_minute.prompt_template_id), 
                  { prompt: 'デフォルトプロンプトを使用（推奨）' }, 
                  { class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors" }
              .mt-1.text-xs.text-gray-600.dark:text-gray-400
                カスタムプロンプトを選択すると、AI生成の精度や形式を調整できます

            / 開催日時
            %div
              = form.label :meeting_date, "開催日時", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
              = form.datetime_local_field :meeting_date, 
                  class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

            / 開催場所
            %div
              = form.label :location, "開催場所", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
              = form.text_field :location, 
                  class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

            / 参加者
            %div
              = form.label :participants, "参加者", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
              = form.text_area :participants, 
                  rows: 3,
                  class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

            / 議事録内容
            %div
              = form.label :content, "議事録内容", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
              
              / AI入力支援機能
              .mb-4.space-y-3
                .border.border-blue-200.rounded-lg.p-4.bg-blue-50
                  .flex.items-center.mb-3
                    %i.fas.fa-robot.text-blue-600.mr-2
                    %span.text-sm.font-medium.text-blue-800 AI入力支援
                    %span.text-xs.text-blue-600.ml-2 音声ファイルや画像から議事録テキストを追加生成できます
                  
                  .grid.grid-cols-1.sm:grid-cols-2.gap-3
                    / 音声ファイルアップロード機能
                    .bg-white.border.border-gray-200.rounded-lg.p-4
                      .text-center
                        %i.fas.fa-microphone.text-green-600.text-2xl.mb-2
                        %h4.text-sm.font-medium.text-gray-900.mb-2 音声から生成
                        %p.text-xs.text-gray-500.mb-3 会議録音から追加内容を生成
                        %input.hidden{ type: "file", accept: "audio/*", id: "meeting-voice-upload", data: { action: "change->file-upload#uploadMeetingVoice" } }
                        %label.cursor-pointer.inline-flex.items-center.px-3.py-2.bg-green-600.text-white.text-sm.rounded-md.hover:bg-green-700.transition-colors{ for: "meeting-voice-upload", id: "voice-upload-label" }
                          🎤 音声ファイル選択
                        / ファイル選択状況表示
                        %div#voice-file-status.hidden.mt-3.text-xs
                          %span.text-green-700.font-medium ✓ ファイル選択完了
                          %span.text-gray-600.ml-2#voice-file-name

                    / 画像ファイルアップロード機能  
                    .bg-white.border.border-gray-200.rounded-lg.p-4
                      .text-center
                        %i.fas.fa-camera.text-purple-600.text-2xl.mb-2
                        %h4.text-sm.font-medium.text-gray-900.mb-2 画像から生成
                        %p.text-xs.text-gray-500.mb-3 ホワイトボードやメモから追加内容を生成
                        %input.hidden{ type: "file", accept: "image/*", id: "meeting-image-upload", data: { action: "change->file-upload#uploadMeetingImage" } }
                        %label.cursor-pointer.inline-flex.items-center.px-3.py-2.bg-purple-600.text-white.text-sm.rounded-md.hover:bg-purple-700.transition-colors{ for: "meeting-image-upload", id: "image-upload-label" }
                          📷 画像ファイル選択
                        / ファイル選択状況表示
                        %div#image-file-status.hidden.mt-3.text-xs
                          %span.text-purple-700.font-medium ✓ ファイル選択完了
                          %span.text-gray-600.ml-2#image-file-name

                  / 処理状況表示（詳細なステータス）- 改善されたローディング
                  #ai-processing-status.hidden.mt-4.p-4.bg-gradient-to-r.from-blue-50.to-purple-50.border-2.border-blue-200.rounded-lg.shadow-inner
                    .flex.items-center.mb-3
                      .relative.mr-3
                        .animate-spin.rounded-full.h-6.w-6.border-3.border-blue-600.border-t-transparent
                        .absolute.inset-1.animate-pulse.rounded-full.bg-blue-100
                      .flex-1
                        %span#processing-message.text-sm.font-semibold.text-blue-800 🤖 AI解析中...
                        %div#detailed-status.text-xs.text-blue-600.mt-1 音声・画像から議事録を自動生成しています
                    / 改良されたプログレスバー
                    .w-full.bg-blue-200.rounded-full.h-2.mt-3.overflow-hidden
                      .bg-gradient-to-r.from-blue-500.to-purple-500.h-2.rounded-full.transition-all.duration-500.animate-pulse#progress-bar{ style: "width: 0%" }
                    / 追加の視覚効果
                    .text-center.mt-3
                      %span.text-xs.text-blue-500.animate-bounce ⏳ 処理が完了するまでお待ちください...
                  
                  / 成功状況表示
                  #upload-success-status.hidden.mt-4.p-3.bg-green-50.border.border-green-200.rounded-lg
                    .flex.items-center
                      %i.fas.fa-check-circle.text-green-600.mr-2
                      %span#success-message.text-sm.text-green-800 生成完了
                  
                  / エラー状況表示
                  #upload-error-status.hidden.mt-4.p-3.bg-red-50.border.border-red-200.rounded-lg
                    .flex.items-center
                      %i.fas.fa-exclamation-triangle.text-red-600.mr-2
                      %span#error-message.text-sm.text-red-800 エラーメッセージ
                  
                  / プログレスバー
                  .hidden.mt-3#progress-container
                    .bg-gray-200.rounded-full.h-2
                      #progress-bar.bg-blue-600.h-2.rounded-full.transition-all.duration-300{ style: "width: 0%" }

                = form.text_area :content, 
                    rows: 20,
                    class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors font-mono text-sm"

              / プレビュー
              - if @meeting_minute.content.present?
                %div
                  %h3.text-sm.font-medium.text-slate-700.dark:text-slate-300.mb-2
                    プレビュー
                  .bg-slate-50.dark:bg-slate-700.rounded-lg.p-6.border.border-slate-200.dark:border-slate-600
                    .prose.max-w-none.text-slate-700.dark:text-slate-300.leading-relaxed.whitespace-pre-line
                      = @meeting_minute.content

            / フォーム送信ボタン（フォームブロック内）
            .mt-6.flex.justify-between.items-center
              = link_to meeting_minute_path(@meeting_minute), 
                  class: "inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors",
                  data: { turbo_frame: "_top" } do
                ← キャンセル
              
              .flex.space-x-2
                - if @meeting_minute.draft? || @meeting_minute.error?
                  = button_to generate_meeting_minute_path(@meeting_minute), method: :post,
                      class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                      data: { file_upload_target: "regenerateButton" } do
                    🤖 AI再生成
                
                = form.submit "💾 議事録を保存", 
                    id: "save-button",
                    class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-200 disabled:opacity-75 disabled:cursor-not-allowed shadow-md hover:shadow-lg transform hover:scale-105 active:scale-95",
                    data: { file_upload_target: "saveButton" },
                    style: "min-width: 140px; transition: all 0.3s ease;"