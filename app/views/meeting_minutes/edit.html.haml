/ 会議議事録編集ページ
.min-h-screen.bg-slate-50.dark:bg-slate-900
  / メインコンテンツエリア
  .pt-4
    .px-4.sm:px-6.lg:px-8.py-8
      / 戻るボタン
      .mb-6
        = link_to meeting_minute_path(@meeting_minute), class: "inline-flex items-center text-sm text-slate-500 hover:text-slate-700" do
          ← 詳細に戻る

      / 編集フォームカード
      .w-full.max-w-none.px-2.sm:px-4
        .bg-white.dark:bg-slate-800.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700.overflow-hidden
          .px-6.py-6.border-b.border-slate-200.dark:border-slate-700
            %h1.text-2xl.font-bold.text-slate-900.dark:text-white
              📝 会議議事録の編集
            %p.mt-2.text-slate-600.dark:text-slate-400
              議事録の内容を編集できます

          = form_with model: @meeting_minute, local: true, class: "px-6 py-6" do |f|
            - if @meeting_minute.errors.any?
              .mb-6.bg-red-50.border.border-red-200.rounded-lg.p-4
                %h3.text-sm.font-medium.text-red-800.mb-2
                  入力内容に問題があります：
                %ul.text-sm.text-red-700.space-y-1
                  - @meeting_minute.errors.full_messages.each do |message|
                    %li= message

            .space-y-6
              / 会議名
              %div
                = f.label :title, "会議名", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = f.text_field :title, class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

              / 議事録タイプ
              %div
                = f.label :meeting_type, "議事録タイプ", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = f.select :meeting_type, options_for_select([['📝 通常の会議議事録', 'regular_meeting'], ['🏥 診察同行の要約', 'medical_visit']], @meeting_minute.meeting_type), {}, { class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors" }

              / 開催日時・場所
              .grid.grid-cols-1.md:grid-cols-2.gap-4
                %div
                  = f.label :meeting_date, "開催日時", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                  = f.datetime_local_field :meeting_date, class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

                %div
                  = f.label :location, "開催場所", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                  = f.text_field :location, class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

              / 参加者
              %div
                = f.label :participants, "参加者", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = f.text_area :participants, rows: 3, class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

              / 議事録内容 + プレビュー（2カラム）
              %div.grid.grid-cols-1.xl:grid-cols-2.gap-6
                %div
                  = f.label :content, "議事録内容", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                  = f.text_area :content, id: "meeting_minute_content", class: "hidden"

                  .rounded-lg.border.border-slate-300.dark:border-slate-600.overflow-hidden
                    .flex.flex-wrap.items-center.gap-2.p-2.bg-slate-100.dark:bg-slate-700.border-b.border-slate-200.dark:border-slate-600
                      %button{ type: "button", data: { editor_command: "bold" }, class: "px-2 py-1 text-xs rounded border border-slate-300 bg-white hover:bg-slate-100 cursor-pointer" } 太字
                      %button{ type: "button", data: { editor_command: "underline" }, class: "px-2 py-1 text-xs rounded border border-slate-300 bg-white hover:bg-slate-100 cursor-pointer" } 下線
                      %button{ type: "button", data: { editor_command: "foreColor", editor_value: "#dc2626" }, class: "px-2 py-1 text-xs rounded border border-slate-300 bg-white hover:bg-slate-100 cursor-pointer" } 赤文字
                      %button{ type: "button", data: { editor_command: "hiliteColor", editor_value: "#fef08a" }, class: "px-2 py-1 text-xs rounded border border-slate-300 bg-white hover:bg-slate-100 cursor-pointer" } 黄マーカー
                      %label.text-xs.text-slate-600
                        文字サイズ
                      %select#editor-font-size.px-2.py-1.text-xs.rounded.border.border-slate-300.bg-white.cursor-pointer
                        %option{ value: "12px" } 小
                        %option{ value: "16px", selected: true } 標準
                        %option{ value: "18px" } 大
                      %button{ type: "button", data: { editor_command: "removeFormat" }, class: "px-2 py-1 text-xs rounded border border-slate-300 bg-white hover:bg-slate-100 cursor-pointer" } 装飾解除

                    %div#meeting_minute_rich_editor.w-full.px-4.py-3.border-0.focus:ring-0.dark:bg-slate-700.dark:text-white.transition-colors.text-base.leading-relaxed{ contenteditable: "true", style: "min-height: 400px; white-space: pre-wrap; word-break: break-word;" }
                      = sanitize(@meeting_minute.content.to_s, tags: %w[p br div strong b u em span mark ul ol li], attributes: %w[style])
                    %p.px-4.py-2.text-xs.text-slate-500.bg-slate-50.dark:bg-slate-800.border-t.border-slate-200.dark:border-slate-600
                      改行・段落を保ったまま編集できます。Enterで改行、ツールバーで装飾できます。

                %div
                  .flex.items-center.justify-between.mb-2
                    %h3.text-sm.font-medium.text-slate-700.dark:text-slate-300
                      プレビュー
                    %span.text-xs.text-slate-400 リアルタイム更新
                  .bg-slate-50.dark:bg-slate-700.rounded-lg.p-6.border.border-slate-200.dark:border-slate-600.overflow-y-auto{"style" => "min-height: 200px; max-height: 600px;"}
                    %div#content-preview.prose.max-w-none.text-base.text-slate-700.dark:text-slate-300.leading-relaxed.whitespace-pre-wrap
                      = sanitize(@meeting_minute.content.to_s, tags: %w[p br div strong b u em span mark ul ol li], attributes: %w[style])

              :javascript
                (function() {
                  var textarea = document.getElementById('meeting_minute_content');
                  var editor   = document.getElementById('meeting_minute_rich_editor');
                  var preview  = document.getElementById('content-preview');

                  if (!textarea || !editor || !preview) return;

                  // プレビューをエディタのHTMLと同期
                  var syncPreview = function() {
                    preview.innerHTML = editor.innerHTML;
                    textarea.value = editor.innerHTML;
                  };

                  // 初期表示
                  syncPreview();

                  // 入力イベント（リアルタイム更新）
                  editor.addEventListener('input', syncPreview);

                  // ツールバーボタン
                  var toolbar = editor.closest('.rounded-lg');
                  var toolbarButtons = toolbar ? toolbar.querySelectorAll('[data-editor-command]') : [];
                  toolbarButtons.forEach(function(btn) {
                    btn.addEventListener('mousedown', function(e) {
                      e.preventDefault();
                    });
                    btn.addEventListener('click', function() {
                      var cmd = btn.dataset.editorCommand;
                      var val = btn.dataset.editorValue || null;
                      document.execCommand('styleWithCSS', false, true);
                      document.execCommand(cmd, false, val);
                      syncPreview();
                    });
                  });

                  // 文字サイズ変更
                  var sizeSelect = document.getElementById('editor-font-size');
                  if (sizeSelect) {
                    sizeSelect.addEventListener('change', function() {
                      document.execCommand('styleWithCSS', false, false);
                      document.execCommand('fontSize', false, '7');
                      editor.querySelectorAll('font[size="7"]').forEach(function(node) {
                        var span = document.createElement('span');
                        span.style.fontSize = sizeSelect.value;
                        while (node.firstChild) span.appendChild(node.firstChild);
                        node.parentNode.replaceChild(span, node);
                      });
                      syncPreview();
                      editor.focus();
                    });
                  }

                  // フォーム送信時に同期
                  var form = editor.closest('form');
                  if (form) {
                    form.addEventListener('submit', syncPreview);
                  }
                })();

            / アクションボタン
            .mt-6.pt-6.border-t.border-slate-200.dark:border-slate-600
              .flex.justify-between.items-center
                = link_to meeting_minute_path(@meeting_minute), class: "inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 transition-colors" do
                  ← キャンセル
                
                .flex.space-x-2
                  - if @meeting_minute.draft? || @meeting_minute.error?
                    = link_to generate_meeting_minute_path(@meeting_minute), method: :post, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors" do
                      🤖 AI再生成
                  
                  = f.submit "💾 保存", class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-green-600 hover:bg-green-700 transition-colors"
