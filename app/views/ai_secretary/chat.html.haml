- content_for :head do
  %style
    :plain
      .chat-sidebar {
        width: 280px;
      }
      .chat-task-panel {
        width: 340px;
      }
      .chat-main {
        width: calc(100% - 620px);
      }
      .messages-container {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
      }
      @media (max-width: 1400px) {
        .chat-task-panel {
          display: none;
        }
        .chat-main {
          width: calc(100% - 280px);
        }
      }
      @media (max-width: 1023px) {
        .chat-sidebar {
          position: fixed !important;
          top: 112px;
          left: 0;
          height: calc(100vh - 112px);
          z-index: 60;
          display: flex !important;
          width: 280px;
          transition: transform 0.3s ease;
          transform: translateX(-100%);
        }
        .chat-sidebar.drawer-open {
          transform: translateX(0);
        }
        .chat-task-panel {
          position: fixed !important;
          top: 112px;
          right: 0;
          height: calc(100vh - 112px);
          z-index: 60;
          display: flex !important;
          width: 300px;
          transition: transform 0.3s ease;
          transform: translateX(100%);
        }
        .chat-task-panel.drawer-open {
          transform: translateX(0);
        }
        .chat-main {
          width: 100% !important;
          padding-top: 48px;
          padding-bottom: 64px;
        }
      }
      /* SP用トグルバー・ヘッダーボタン */
      .sp-toggle-bar,
      .sp-header-btn {
        display: flex;
      }
      @media (min-width: 1024px) {
        .sp-toggle-bar,
        .sp-header-btn {
          display: none !important;
        }
      }

.min-h-screen.bg-slate-50.dark:bg-slate-900{ data: { controller: "sp-drawer" } }
  / SP用バックドロップ（ドロワー背景の暗幕）
  .fixed.inset-0.z-50.bg-black.bg-opacity-50.hidden{ data: { sp_drawer_target: "backdrop", action: "click->sp-drawer#closeAll" }, style: "display:none" }

  / SP専用トグルバー（チャット履歴 ／ タスク・予定 を開くボタン）
  .sp-toggle-bar.fixed.top-16.left-0.right-0.z-40.bg-white.dark:bg-slate-800.border-b.border-slate-200.dark:border-slate-700.items-center.justify-between.px-3.py-2{ style: "display:flex" }
    %button.flex.items-center.gap-2.px-3.py-2.bg-slate-100.hover:bg-slate-200.dark:bg-slate-700.dark:hover:bg-slate-600.rounded-lg.text-sm.font-medium.text-slate-700.dark:text-slate-200.transition-colors{
      data: { action: "click->sp-drawer#openLeft" }
    }
      %i.fas.fa-bars
      %span チャット履歴
    %span.text-xs.text-slate-400.dark:text-slate-500 AI秘書
    %button.flex.items-center.gap-2.px-3.py-2.bg-slate-100.hover:bg-slate-200.dark:bg-slate-700.dark:hover:bg-slate-600.rounded-lg.text-sm.font-medium.text-slate-700.dark:text-slate-200.transition-colors{
      data: { action: "click->sp-drawer#openRight" }
    }
      %span タスク・予定
      %i.fas.fa-tasks

  .flex.overflow-hidden{ style: "height: calc(100vh - 64px)" }
    / 左サイドバー - 会話履歴（SP: 初期非表示のドロワー）
    .chat-sidebar.bg-white.dark:bg-slate-800.border-r.border-slate-200.dark:border-slate-700.flex.flex-col{ data: { controller: "conversation-sidebar", sp_drawer_target: "leftDrawer" } }
      / サイドバーヘッダー
      .flex-shrink-0.px-4.py-4.border-b.border-slate-200.dark:border-slate-700
        .flex.items-center.justify-between.mb-3
          %h2.text-lg.font-semibold.text-slate-900.dark:text-white
            %i.fas.fa-comments.mr-2
            チャット履歴
          .flex.items-center.gap-2
            %button.p-2.bg-blue-600.text-white.rounded-lg.hover:bg-blue-700.transition-colors{ 
              data: { action: "click->conversation-sidebar#newConversation" },
              title: "新しい会話を開始"
            }
              %i.fas.fa-plus
            / SP用閉じるボタン
            %button.p-2.text-slate-500.hover:bg-slate-100.rounded-lg.transition-colors.lg:hidden{
              data: { action: "click->sp-drawer#closeAll" },
              title: "閉じる"
            }
              %i.fas.fa-times

        / 検索フィルター
        .relative
          %input.w-full.px-3.py-2.pl-8.text-sm.border.border-slate-300.dark:border-slate-600.rounded-lg.focus:ring-2.focus:ring-blue-500.focus:border-blue-500.dark:bg-slate-700.dark:text-white{ 
            type: "text", 
            placeholder: "会話を検索...",
            data: { conversation_sidebar_target: "searchInput", action: "input->conversation-sidebar#filterConversations" }
          }
          %i.fas.fa-search.absolute.left-3.top-3.text-slate-400.text-xs

      / 会話リスト
      .flex-1.overflow-y-auto.px-2.py-2
        #conversation-list{ data: { conversation_sidebar_target: "conversationList" } }
          .flex.items-center.justify-center.py-8.text-slate-500
            %i.fas.fa-spinner.fa-spin.mr-2
            読み込み中...

      / サイドバーフッター
      .flex-shrink-0.px-4.py-3.border-t.border-slate-200.dark:border-slate-700
        = link_to dashboard_path, class: "inline-flex items-center w-full px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-100 dark:hover:text-white dark:hover:bg-slate-700 rounded-lg transition-colors" do
          %i.fas.fa-arrow-left.mr-2
          ダッシュボードに戻る

    / メインチャットエリア
    .chat-main.flex.flex-col.overflow-hidden
      / チャットヘッダー
      .flex-shrink-0.bg-white.dark:bg-slate-800.border-b.border-slate-200.dark:border-slate-700.px-4.lg:px-6.py-4
        .flex.items-center.justify-between
          .flex.items-center.space-x-2.lg:space-x-4
            / SP用：チャット履歴ドロワーを開くボタン
            %button.p-2.text-slate-500.hover:text-slate-700.hover:bg-slate-100.rounded-lg.transition-colors.sp-header-btn{
              data: { action: "click->sp-drawer#openLeft" },
              title: "チャット履歴"
            }
              %i.fas.fa-bars
            .bg-gradient-to-br.from-indigo-500.to-blue-600.p-3.rounded-full
              🤝
            %div
              %h1.text-base.lg:text-xl.font-bold.text-slate-900.dark:text-white
                パーソナル・ビジネスエージェント
                %span#conversation-title.ml-2.text-sm.font-normal.text-slate-500{ data: { conversation_sidebar_target: "conversationTitle" } }
              .flex.items-center.flex-wrap.gap-2.mt-1
                %span.px-2.py-0.5.bg-green-100.text-green-800.dark:bg-green-900.dark:text-green-200.text-xs.rounded-full
                  🌐 Web検索対応
                %span{ data: { ai_chat_target: "modeBadge" }, class: "px-2 py-0.5 bg-indigo-100 text-indigo-800 dark:bg-indigo-900 dark:text-indigo-200 text-xs rounded-full" }
                  🗂 秘書モード
          .flex.items-center.space-x-2
            %button.p-2.text-slate-500.hover:text-slate-700.hover:bg-slate-100.rounded-lg.transition-colors{ 
              title: "会話をクリア",
              data: { action: "click->conversation-sidebar#clearConversation" }
            }
              %i.fas.fa-trash-alt
            / SP用：タスクパネルドロワーを開くボタン
            %button.p-2.text-slate-500.hover:text-slate-700.hover:bg-slate-100.rounded-lg.transition-colors.sp-header-btn{
              data: { action: "click->sp-drawer#openRight" },
              title: "タスク・予定"
            }
              %i.fas.fa-tasks

      / チャットメッセージエリア
      .flex-1.overflow-hidden{ data: { controller: "ai-chat", ai_chat_conversation_id_value: @conversation_id } }
        .h-full.flex.flex-col
          / メッセージリスト
          .messages-container.px-4.lg:px-6.py-4.bg-slate-50.dark:bg-slate-900{ data: { ai_chat_target: "messagesContainer" } }
            %div#chat-messages
              - if @recent_messages.any?
                - @recent_messages.each do |message|
                  - if message.role == "user"
                    .flex.justify-end.mb-4
                      .max-w-lg.bg-blue-600.text-white.rounded-2xl.px-4.py-3.shadow-sm
                        = simple_format(message.content, class: "text-sm leading-relaxed")
                        .text-xs.text-blue-200.mt-2.text-right= message.created_at.strftime("%H:%M")
                  - elsif message.role == "assistant"
                    .flex.justify-start.mb-4
                      .flex.items-start.space-x-3.max-w-lg
                        .bg-blue-500.p-2.rounded-full.flex-shrink-0.mt-1
                          %i.fas.fa-robot.text-white.text-sm
                        %div
                          .bg-white.dark:bg-slate-700.text-slate-900.dark:text-slate-100.rounded-2xl.px-4.py-3.shadow-sm.border.border-slate-200.dark:border-slate-600
                            = simple_format(message.content, class: "text-sm leading-relaxed whitespace-pre-wrap")
                          .text-xs.text-slate-500.dark:text-slate-400.mt-2.ml-1= message.created_at.strftime("%H:%M")
              - else
                .flex.flex-col.items-center.justify-center.h-full.text-slate-500.dark:text-slate-400
                  .bg-slate-100.dark:bg-slate-800.p-6.rounded-2xl.max-w-lg.text-center
                    .text-4xl.mb-3 🤝
                    %h3.text-base.font-semibold.mb-1.text-slate-800.dark:text-slate-200
                      篠原さん、おはようございます。
                    %p.text-xs.mb-4.text-slate-600.dark:text-slate-400
                      パーソナル・ビジネスエージェントです。何でもお気軽にどうぞ。
                    .grid.grid-cols-2.gap-2.text-left.text-xs
                      .bg-white.dark:bg-slate-700.rounded-xl.p-2.border.border-slate-200.dark:border-slate-600
                        .font-semibold.text-indigo-600.dark:text-indigo-400.mb-0.5 🗂 秘書モード
                        スケジュール確認・タスク整理
                      .bg-white.dark:bg-slate-700.rounded-xl.p-2.border.border-slate-200.dark:border-slate-600
                        .font-semibold.text-teal-600.dark:text-teal-400.mb-0.5 🏥 MHSW相談
                        訪問支援・福祉制度
                      .bg-white.dark:bg-slate-700.rounded-xl.p-2.border.border-slate-200.dark:border-slate-600
                        .font-semibold.text-amber-600.dark:text-amber-400.mb-0.5 💼 ビジネス相談
                        freee・Rails・事業アドバイス
                      .bg-white.dark:bg-slate-700.rounded-xl.p-2.border.border-slate-200.dark:border-slate-600
                        .font-semibold.text-pink-600.dark:text-pink-400.mb-0.5 💆 メンタル管理
                        疲労・ストレス・セルフケア

          / メッセージ入力エリア
          .flex-shrink-0.border-t.border-slate-200.dark:border-slate-700.bg-white.dark:bg-slate-800.px-4.py-4
            .max-w-3xl.mx-auto.w-full
              = form_with url: ai_secretary_send_message_path, local: false, class: "flex items-end space-x-3", data: { ai_chat_target: "form", action: "submit->ai-chat#sendMessage" } do |form|
                .flex-1
                  = form.text_area :message, rows: 2, class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white resize-none", placeholder: "メッセージを入力してください... （最新情報が必要な場合は「調べて」「検索して」等を含めてください）", data: { ai_chat_target: "messageInput", action: "keypress->ai-chat#handleKeyPress input->ai-chat#saveDraft" }
                = hidden_field_tag :conversation_id, @conversation_id
                = form.submit "送信", class: "px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-2xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed", data: { ai_chat_target: "submitButton" }
              / 送信状態の表示
              .mt-2.text-center.hidden{ data: { ai_chat_target: "loadingIndicator" } }
                %i.fas.fa-spinner.fa-spin.mr-2
                %span.text-sm.text-slate-500 AI秘書が応答中...

      / 機能案内
      .flex-shrink-0.bg-slate-100.dark:bg-slate-800.px-6.py-2.text-center
        .text-xs.text-slate-500.dark:text-slate-400
          💡 入力例：「今日の予定は？」「訪問支援の記録を整理して」「疲れたので気分転換のアイデアを教えて」
          ／ 最新情報が必要なときは「調べて」「検索して」を含めてください

    / 右サイドパネル - タスク・予定（SP: 初期非表示のドロワー）
    .chat-task-panel.bg-white.dark:bg-slate-800.border-l.border-slate-200.dark:border-slate-700.flex.flex-col{ data: { sp_drawer_target: "rightDrawer" } }
      .flex-shrink-0.px-4.py-4.border-b.border-slate-200.dark:border-slate-700
        .flex.items-center.justify-between
          %div
            %h2.text-base.font-semibold.text-slate-900.dark:text-white
              %i.fas.fa-tasks.mr-2.text-emerald-600
              やること・予定
            %p.text-xs.text-slate-500.dark:text-slate-400.mt-1
              未完了タスクと今後14日間の予定
          / SP用閉じるボタン
          %button.p-2.text-slate-500.hover:bg-slate-100.rounded-lg.transition-colors.lg:hidden{
            data: { action: "click->sp-drawer#closeAll" },
            title: "閉じる"
          }
            %i.fas.fa-times
        .mt-3
          = button_to ai_secretary_extract_tasks_from_chat_path,
            method: :post,
            params: { conversation_id: @conversation_id },
            class: "inline-flex items-center justify-center w-full px-3 py-2 text-xs font-medium bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors",
            data: { confirm: "この会話から予定・タスク候補を抽出してドラフト作成しますか？", disable_with: "🤖 抽出中..." } do
            %i.fas.fa-magic.mr-2
            この会話を抽出してドラフト作成

      .flex-1.overflow-y-auto.p-3
        / 未完了タスク
        %p.text-xs.font-semibold.text-slate-500.dark:text-slate-400.uppercase.tracking-wide.mb-2
          %i.fas.fa-check-square.mr-1
          未完了タスク
        - if @pending_tasks.present?
          .space-y-2.mb-4
            - @pending_tasks.each do |task|
              .rounded-lg.border.border-slate-200.dark:border-slate-700.bg-slate-50.dark:bg-slate-900.p-2.5
                .flex.items-start.gap-2
                  .mt-0.5
                    - if task.due_date.present? && task.due_date < Time.current
                      %i.fas.fa-exclamation-circle.text-red-500.text-xs
                    - elsif task.due_date.present? && task.due_date < 1.day.from_now
                      %i.fas.fa-clock.text-amber-500.text-xs
                    - else
                      %i.far.fa-circle.text-slate-400.text-xs
                  %div.min-w-0.flex-1
                    %p.text-sm.text-slate-800.dark:text-slate-100.font-medium.leading-tight.truncate
                      = task.title
                    - if task.due_date.present?
                      %p.text-xs.mt-0.5
                        - if task.due_date < Time.current
                          %span.text-red-500= "期限切れ: #{task.due_date.strftime('%m/%d %H:%M')}"
                        - else
                          %span.text-slate-500.dark:text-slate-400= "期限: #{task.due_date.strftime('%m/%d %H:%M')}"
                    - if task.is_draft
                      %span.text-xs.text-amber-600.bg-amber-50.dark:bg-amber-900.dark:text-amber-300.px-1.5.py-0.5.rounded.mt-1.inline-block 下書き
        - else
          .text-center.py-3.text-sm.text-slate-400.dark:text-slate-500.mb-4
            未完了のタスクはありません

        / 今後の予定
        %p.text-xs.font-semibold.text-slate-500.dark:text-slate-400.uppercase.tracking-wide.mb-2.mt-2
          %i.fas.fa-calendar-alt.mr-1
          今後の予定（14日間）
        - if @upcoming_events.present?
          .space-y-2
            - @upcoming_events.each do |event|
              .rounded-lg.border.border-slate-200.dark:border-slate-700.bg-slate-50.dark:bg-slate-900.p-2.5
                .flex.items-start.gap-2
                  .w-2.h-2.rounded-full.flex-shrink-0.mt-1.5{ style: "background-color: #{event.display_color}" }
                  %div.min-w-0.flex-1
                    %p.text-sm.text-slate-800.dark:text-slate-100.font-medium.leading-tight.truncate
                      = event.title
                    %p.text-xs.text-slate-500.dark:text-slate-400.mt-0.5
                      = event.all_day ? event.start_time.strftime("%m/%d 終日") : event.start_time.strftime("%m/%d %H:%M")
                    - if event.location.present?
                      %p.text-xs.text-slate-400.dark:text-slate-500.truncate
                        %i.fas.fa-map-marker-alt.mr-1
                        = event.location
        - else
          .text-center.py-3.text-sm.text-slate-400.dark:text-slate-500
            今後14日間に予定はありません

      .flex-shrink-0.p-3.border-t.border-slate-200.dark:border-slate-700.space-y-2
        = link_to tasks_path, class: "inline-flex items-center justify-center w-full px-3 py-2 text-sm font-medium bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors" do
          %i.fas.fa-tasks.mr-2
          タスク一覧
        = link_to calendar_index_path, class: "inline-flex items-center justify-center w-full px-3 py-2 text-sm font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" do
          %i.fas.fa-calendar.mr-2
          カレンダーを開く