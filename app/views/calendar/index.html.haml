:css
  /* 月ビュー: 日付番号をリンクに */
  .calendar-date-number-link {
    text-decoration: none;
    color: inherit;
    display: inline-flex;
    align-items: center;
  }
  .calendar-date-number-link:hover .calendar-date-number {
    background-color: #e0e7ff;
    border-radius: 50%;
  }

  /* ─────────────────────────────────────── */
  /* 週ビュー                                */
  /* ─────────────────────────────────────── */
  .week-grid-wrapper {
    display: flex;
    flex-direction: column;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    background: white;
  }

  /* 曜日ヘッダー */
  .week-header-row {
    display: grid;
    grid-template-columns: 52px repeat(7, 1fr);
    border-bottom: 2px solid #e5e7eb;
    background: #f9fafb;
    position: sticky;
    top: 0;
