  // 開始日時変更時の終了日時自動設定
  function setupDateTimeAutoCalculation() {
    // 新規作成モーダル
    ['event-start-date-part', 'event-start-hour-part', 'event-start-min-part'].forEach(function(id) {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('change', function() {
          syncDatetimeHidden('event-start-date-part', 'event-start-hour-part', 'event-start-min-part', 'event-start-input');
          const startHidden = document.getElementById('event-start-input');
          if (startHidden && startHidden.value) {
            updateEndTimeOneHourLater(startHidden.value, 'event-end-date-part', 'event-end-hour-part', 'event-end-min-part', 'event-end-input');
          }
        });
      }
    });
    // 編集モーダル
    ['edit-start-date-part', 'edit-start-hour-part', 'edit-start-min-part'].forEach(function(id) {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('change', function() {
          syncDatetimeHidden('edit-start-date-part', 'edit-start-hour-part', 'edit-start-min-part', 'edit-event-start');
          const startHidden = document.getElementById('edit-event-start');
          if (startHidden && startHidden.value) {
            updateEndTimeOneHourLater(startHidden.value, 'edit-end-date-part', 'edit-end-hour-part', 'edit-end-min-part', 'edit-event-end');
          }
        });
      }
    });
  }

  // 1時間後の時刻設定（終了日時が開始より前の場合のみ上書き）
  function updateEndTimeOneHourLater(startTimeValue, endDateId, endHourId, endMinId, endHiddenId) {
    if (!startTimeValue) return;
    try {
      const startDate = new Date(startTimeValue);
      const endHiddenEl = document.getElementById(endHiddenId);
      const currentEnd = endHiddenEl?.value ? new Date(endHiddenEl.value) : null;
      // 既に開始より後の終了時刻が設定されている場合は上書きしない
      if (currentEnd && currentEnd > startDate) return;
      const endDate = new Date(startDate.getTime() + 60 * 60 * 1000);
      setDatetimeParts(endDate.toISOString(), endDateId, endHourId, endMinId, endHiddenId);
    } catch (error) {
      console.error('Error calculating end time:', error);
    }
  }

