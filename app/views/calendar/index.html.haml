  function formatDateTime(dateTimeString) {
    if (!dateTimeString) return '';
    
    const date = new Date(dateTimeString);
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    const hours = String(date.getHours()).padStart(2, '0');
    const minutes = String(date.getMinutes()).padStart(2, '0');
    
    return `${year}年${month}月${day}日 ${hours}:${minutes}`;
  }

  function formatDateTimeForInput(dateTimeString) {
    if (!dateTimeString) return '';
    
    const date = new Date(dateTimeString);
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    const hours = String(date.getHours()).padStart(2, '0');
    const minutes = String(date.getMinutes()).padStart(2, '0');
    
    return `${year}-${month}-${day}T${hours}:${minutes}`;
  }

  // 分を15分単位に丸める
  function snapToQuarterHour(datetimeLocalString) {
    if (!datetimeLocalString) return datetimeLocalString;
    const [datePart, timePart] = datetimeLocalString.split('T');
    if (!datePart || !timePart) return datetimeLocalString;
    const [hour, minute] = timePart.split(':').map(Number);
    const snappedMinute = Math.round(minute / 15) * 15;
    const extraHour = snappedMinute >= 60 ? 1 : 0;
    const finalMinute = snappedMinute >= 60 ? 0 : snappedMinute;
    const finalHour = hour + extraHour;
    if (finalHour >= 24) {
      const d = new Date(datePart + 'T00:00:00');
      d.setDate(d.getDate() + 1);
      const yr = d.getFullYear();
      const mo = String(d.getMonth() + 1).padStart(2, '0');
      const dy = String(d.getDate()).padStart(2, '0');
      return `${yr}-${mo}-${dy}T00:00`;
    }
    return `${datePart}T${String(finalHour).padStart(2, '0')}:${String(finalMinute).padStart(2, '0')}`;
  }

  // 日付・時・分セレクトの値を隠しフィールドに同期
  function syncDatetimeHidden(dateId, hourId, minId, hiddenId) {
    const datePart = document.getElementById(dateId)?.value;
    const hourPart = document.getElementById(hourId)?.value;
    const minPart  = document.getElementById(minId)?.value;
    if (!datePart || hourPart === undefined || minPart === undefined) return;
    const hidden = document.getElementById(hiddenId);
    if (hidden) hidden.value = `${datePart}T${hourPart}:${minPart}`;
  }

  // 隠しフィールドと各セレクトに日時値をセット（15分単位に丸める）
  function setDatetimeParts(datetimeValue, dateId, hourId, minId, hiddenId) {
    const snapped = snapToQuarterHour(formatDateTimeForInput(datetimeValue));
    if (!snapped) return;
    const [datePart, timePart] = snapped.split('T');
    const [hh, mm] = timePart.split(':');
    const dateEl = document.getElementById(dateId);
    const hourEl = document.getElementById(hourId);
    const minEl  = document.getElementById(minId);
    if (dateEl) dateEl.value = datePart;
    if (hourEl) hourEl.value = hh;
    if (minEl)  minEl.value  = mm;
    syncDatetimeHidden(dateId, hourId, minId, hiddenId);
  }

  function getEventTypeLabel(eventType) {
    if (!window.customCategories) return eventType;
    
    const category = window.customCategories.find(cat => (cat.id || cat['id']) === eventType);
    return category ? (category.name || category['name']) : eventType;
  }

  function submitEventForm() {
    const form = document.getElementById('event-form');
    const submitBtn = document.getElementById('submit-btn');
    
    if (!form || !submitBtn) return;

    // 終日チェック時: dateフィールドをdatetimeに変換してからFormData生成
    const alldayCheck = document.getElementById('event-allday-check');
    if (alldayCheck && alldayCheck.checked) {
      const startDate = document.getElementById('event-start-date');
      const endDate   = document.getElementById('event-end-date');
      // hidden inputとして datetime 値を注入
      if (startDate && startDate.value) {
        document.getElementById('event-start-input').value = startDate.value + 'T00:00';
      }
      if (endDate && endDate.value) {
        document.getElementById('event-end-input').value = endDate.value + 'T23:59';
      }
      // 終日フィールドのname属性を一時的に無効化して重複送信を防ぐ
      if (startDate) startDate.removeAttribute('name');
      if (endDate)   endDate.removeAttribute('name');
      document.getElementById('event-start-input').setAttribute('name', 'event[start_time]');
      document.getElementById('event-end-input').setAttribute('name', 'event[end_time]');
    } else {
      // hidden input が空でも、表示中の date/hour/minute から必ず再構築する
      syncDatetimeHidden('event-start-date-part', 'event-start-hour-part', 'event-start-min-part', 'event-start-input');
      syncDatetimeHidden('event-end-date-part', 'event-end-hour-part', 'event-end-min-part', 'event-end-input');

      const startHidden = document.getElementById('event-start-input');
      const endHidden = document.getElementById('event-end-input');

      if (!startHidden?.value || !endHidden?.value) {
        const now = new Date();
        setDatetimeParts(now.toISOString(), 'event-start-date-part', 'event-start-hour-part', 'event-start-min-part', 'event-start-input');
        const endNow = new Date(now.getTime() + 60 * 60 * 1000);
        setDatetimeParts(endNow.toISOString(), 'event-end-date-part', 'event-end-hour-part', 'event-end-min-part', 'event-end-input');
      }
    }

    const startValue = document.getElementById('event-start-input')?.value;
    const endValue = document.getElementById('event-end-input')?.value;
    if (!startValue || !endValue) {
      showErrorMessages(['開始日時と終了日時を入力してください。']);
      return;
    }

    const formData = new FormData(form);
    const token = document.querySelector('meta[name="csrf-token"]');
    
    if (token) {
      formData.append('authenticity_token', token.getAttribute('content'));
    }
    
    // デバッグ: FormDataの内容をログ出力
    console.log('📝 Submitting event form with FormData:');
    for (let [key, value] of formData.entries()) {
      console.log(`  ${key}: ${value}`);
    }
    
    submitBtn.disabled = true;
    submitBtn.textContent = '作成中...';
    
    fetch('/calendar', {
      method: 'POST',
      body: formData,
      headers: {
        'X-CSRF-Token': token ? token.getAttribute('content') : '',
        'Accept': 'application/json'
      }
    })
    .then(response => {
      if (response.ok) {
        closeEventModal();
        window.location.reload();
      } else {
        return response.text().then(text => {
          let errorMessage = ['予期しないエラーが発生しました。'];
          try {
            const errorData = JSON.parse(text);
            if (errorData.errors) {
              if (typeof errorData.errors === 'object') {
                errorMessage = Object.values(errorData.errors).flat();
              } else if (Array.isArray(errorData.errors)) {
                errorMessage = errorData.errors;
              } else {
                errorMessage = [errorData.errors];
              }
            } else if (errorData.error) {
              errorMessage = [errorData.error];
            }
          } catch (e) {
            errorMessage = [`サーバーエラー: ${response.status} ${response.statusText}`];
          }
          showErrorMessages(errorMessage);
        });
      }
    })
    .catch(error => {
      console.error('Network error:', error);
      showErrorMessages(['ネットワークエラーが発生しました: ' + error.message]);
    })
    .finally(() => {
      submitBtn.disabled = false;
      submitBtn.textContent = '作成';
    });
  }

