:javascript
  // Turbo対応のカレンダー機能
  document.addEventListener('turbo:load', function() {
    initializeCalendar();
  });

  document.addEventListener('DOMContentLoaded', function() {
    if (document.readyState !== 'loading') {
      initializeCalendar();
    }
  });

  // 初期化フラグリセット
  document.addEventListener('turbo:before-render', function() {
    window.calendarInitialized = false;
  });

  // グローバル変数：現在選択されているイベント
  window.currentEvent = null;

  // カスタムカテゴリの情報をJavaScript変数として定義
  window.customCategories = #{@custom_categories.to_json.html_safe};

  // カレンダー初期化関数
  function initializeCalendar() {
    if (window.calendarInitialized) {
      console.log('Calendar already initialized, skipping...');
      return;
    }

    console.log('=== Initializing Calendar ===');
    
    try {
      // 月表示の更新
      updateMonthDisplay();
      
      // イベントに動的色を適用
      applyEventColors();
      
      // CSRFトークンをフォームに設定
      setupCSRFToken();
      
      // ビュー切り替えボタンの設定
      setupViewButtons();
      
      // フォーム送信の設定
      setupFormSubmissions();
      
      // 開始日時変更時の終了日時自動設定
      setupDateTimeAutoCalculation();
      
      // ナビゲーションボタンの設定
      setupNavigationButtons();
      
      window.calendarInitialized = true;
      console.log('=== Calendar initialization complete ===');
      
    } catch (error) {
      console.error('Failed to initialize calendar:', error);
      window.calendarInitialized = false;
    }
  }

  // 月表示更新関数
  function updateMonthDisplay() {
    const calendarContainer = document.querySelector('.calendar-container');
    if (!calendarContainer || !calendarContainer.dataset.currentDate) {
      console.warn('Cannot update month display: calendar container or date not found');
      return;
    }
    
    try {
      const currentDate = new Date(calendarContainer.dataset.currentDate);
      const monthNames = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
      const displayText = `${currentDate.getFullYear()}年${monthNames[currentDate.getMonth()]}`;
      
      const monthElement = document.getElementById('current-month');
      if (monthElement) {
        monthElement.textContent = displayText;
        console.log('Month display updated to:', displayText);
      }
    } catch (error) {
      console.error('Error updating month display:', error);
    }
  }

  // イベントの動的色適用
  function applyEventColors() {
    console.log('Applying dynamic colors to events...');
    
    if (!window.customCategories) {
      console.warn('Custom categories not loaded yet');
      return;
    }
    
    const eventElements = document.querySelectorAll('.calendar-event, .week-event-block');
    console.log(`Found ${eventElements.length} event elements`);
    
    eventElements.forEach(eventElement => {
      const eventType = eventElement.dataset.eventType;
      if (!eventType) {
        console.warn('Event element missing event_type data');
        return;
      }
      
      // 対応するカテゴリを検索
      const category = window.customCategories.find(cat => 
        (cat.id || cat['id']) === eventType
      );
      
      if (category) {
        const color = category.color || category['color'] || '#6B7280';
        const colors = calculateEventColors(color);
        
        // スタイルを適用
        eventElement.style.backgroundColor = colors.background;
        eventElement.style.borderLeftColor = colors.border;
        eventElement.style.color = colors.text;
        
        console.log(`Applied color ${color} to event type ${eventType}`);
      } else {
        console.warn(`No category found for event type: ${eventType}`);
        // デフォルト色を適用
        eventElement.style.backgroundColor = '#f3f4f6';
        eventElement.style.borderLeftColor = '#6b7280';
        eventElement.style.color = '#374151';
      }
    });
  }

  // 色計算関数
  function calculateEventColors(baseColor) {
    let r, g, b;
    if (baseColor.startsWith('#')) {
      const hex = baseColor.slice(1);
      r = parseInt(hex.substr(0, 2), 16);
      g = parseInt(hex.substr(2, 2), 16);
      b = parseInt(hex.substr(4, 2), 16);
    } else {
      return { background: '#f3f4f6', border: '#6b7280', text: '#374151' };
    }
    
    // 薄い背景色を生成
    const backgroundR = Math.min(255, r + (255 - r) * 0.8);
    const backgroundG = Math.min(255, g + (255 - g) * 0.8);
    const backgroundB = Math.min(255, b + (255 - b) * 0.8);
    const background = `rgba(${backgroundR}, ${backgroundG}, ${backgroundB}, 0.3)`;
    
    // 枠線色は元の色
    const border = baseColor;
    
    // 文字色は元の色を暗くしたもの
    const textR = Math.floor(r * 0.7);
    const textG = Math.floor(g * 0.7);
    const textB = Math.floor(b * 0.7);
    const text = `rgb(${textR}, ${textG}, ${textB})`;
    
    return { background, border, text };
  }

