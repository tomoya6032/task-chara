  function performEditEventUpdate(scope) {
    const form = document.getElementById('event-edit-form');
    const submitBtn = document.getElementById('edit-submit-btn');
    const eventId = document.getElementById('edit-event-id');
    
    if (!form || !eventId || !eventId.value) {
      alert('フォームデータが不正です。');
      return;
    }
    
    console.log('performEditEventUpdate - Full event object:', JSON.stringify(window.currentEvent, null, 2));
    console.log('Updating event with scope:', scope, 'Event ID:', eventId.value, 'occurrence_time:', window.currentEvent?.occurrence_time);
    
    const formData = new FormData(form);
    const token = document.querySelector('meta[name="csrf-token"]');
    
    if (token) {
      formData.append('authenticity_token', token.getAttribute('content'));
    }
    
    if (scope) {
      formData.append('edit_scope', scope);
    }
    
    // 開始時刻パラメータを追加（繰り返しインスタンスの場合）
    if (window.currentEvent && window.currentEvent.occurrence_time) {
      formData.append('occurrence_time', window.currentEvent.occurrence_time);
      console.log('Added occurrence_time to form:', window.currentEvent.occurrence_time);
    } else {
      console.warn('No occurrence_time available to send');
    }
    
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = '更新中...';
    }
    
    const editModal = document.getElementById('event-edit-modal');
    
    fetch(`/calendar/${eventId.value}`, {
      method: 'PUT',
      body: formData,
      headers: {
        'X-CSRF-Token': token ? token.getAttribute('content') : '',
        'Accept': 'application/json'
      }
    })
    .then(response => {
      if (response.ok) {
        if (editModal) editModal.classList.add('hidden');
        window.location.reload();
      } else {
        return response.text().then(text => {
          let errorMessage = ['予期しないエラーが発生しました。'];
          try {
            const errorData = JSON.parse(text);
            if (errorData.errors) {
              if (typeof errorData.errors === 'object') {
                errorMessage = Object.values(errorData.errors).flat();
              } else if (Array.isArray(errorData.errors)) {
                errorMessage = errorData.errors;
              } else {
                errorMessage = [errorData.errors];
              }
            } else if (errorData.error) {
              errorMessage = [errorData.error];
            }
          } catch (e) {
            if (text.includes('開始時刻より後である必要があります')) {
              errorMessage = ['終了時刻は開始時刻より後に設定してください。'];
            } else {
              errorMessage = [`サーバーエラー: ${response.status} ${response.statusText}`];
            }
          }
          // 編集モーダルを再表示してエラーを表示
          if (editModal) editModal.classList.remove('hidden');
          showEditErrorMessages(errorMessage);
        });
      }
    })
    .catch(error => {
      console.error('Edit network error:', error);
      if (editModal) editModal.classList.remove('hidden');
      showEditErrorMessages(['ネットワークエラーが発生しました: ' + error.message]);
    })
    .finally(() => {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = '更新';
      }
    });
  }

