                  %select#recurring-interval.rounded-md.px-3.py-2{ name: "event[recurrence][interval]", class: "border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white" }
                    - (1..12).each do |i|
                      %option{ value: i, selected: i == 1 }= i
