                  曜日を選択
                .flex.flex-wrap.gap-2
                  - %w[monday tuesday wednesday thursday friday saturday sunday].each_with_index do |day, idx|
                    - day_label = %w[月 火 水 木 金 土 日][idx]
                    .flex.items-center
                      %input{ type: "checkbox", id: "day-#{day}", name: "event[recurrence][days_of_week][]", value: day, class: "w-4 h-4 text-blue-600 border-gray-300 rounded" }
                      %label{ for: "day-#{day}", class: "ml-1 text-sm text-gray-700 dark:text-gray-300" }= day_label

              / 終了条件
              .mb-3
                %label.block.text-sm.font-medium.mb-2{ class: "text-gray-700 dark:text-gray-300" }
                  終了条件
                .space-y-2
                  .flex.items-center.gap-2
                    %input#end-never{ type: "radio", name: "event[recurrence][end_type]", value: "never", checked: true, class: "w-4 h-4 text-blue-600" }
                    %label{ for: "end-never", class: "text-sm text-gray-700 dark:text-gray-300" } 終了なし
                  
                  .flex.items-center.gap-2
                    %input#end-date{ type: "radio", name: "event[recurrence][end_type]", value: "date", class: "w-4 h-4 text-blue-600", onchange: "toggleEndDateInput()" }
                    %label{ for: "end-date", class: "text-sm text-gray-700 dark:text-gray-300" } 終了日
                    %input#end-date-input.rounded-md.px-2.py-1.text-sm{ type: "date", name: "event[recurrence][end_date]", disabled: true, class: "border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white" }
                  
                  .flex.items-center.gap-2
                    %input#end-count{ type: "radio", name: "event[recurrence][end_type]", value: "count", class: "w-4 h-4 text-blue-600", onchange: "toggleEndCountInput()" }
                    %label{ for: "end-count", class: "text-sm text-gray-700 dark:text-gray-300" } 回数指定
                    %input#end-count-input.rounded-md.px-2.py-1.text-sm.w-20{ type: "number", name: "event[recurrence][count]", min: "1", max: "999", value: "10", disabled: true, class: "border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white" }
