  // 月ナビゲーション
  window.navigateToMonth = function(direction) {
    console.log('=== navigateToMonth START ===', direction);
    
    try {
      const calendarContainer = document.querySelector('.calendar-container');
      if (!calendarContainer) {
        alert('カレンダーコンテナが見つかりません');
        return;
      }
      
      const currentDateString = calendarContainer.dataset.currentDate;
      if (!currentDateString) {
        alert('日付データが見つかりません');
        return;
      }
      
      const currentDate = new Date(currentDateString);
      currentDate.setMonth(currentDate.getMonth() + direction);
      
      const year = currentDate.getFullYear();
      const month = String(currentDate.getMonth() + 1).padStart(2, '0');
      const dateParam = `${year}-${month}-01`;
      
      const targetUrl = `/calendar?date=${dateParam}`;
      console.log('Navigating to:', targetUrl);
      
      window.location.assign(targetUrl);
      
    } catch (error) {
      console.error('Error in navigateToMonth:', error);
      alert('月の切り替えでエラーが発生しました: ' + error.message);
    }
  };

