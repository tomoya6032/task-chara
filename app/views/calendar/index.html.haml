  window.notifyEventToLine = function() {
    if (!window.currentEvent || !window.currentEvent.id) {
      alert('通知するイベントが選択されていません。');
      return;
    }

    const notifyBtn = document.getElementById('notify-event-btn');
    if (notifyBtn) {
      notifyBtn.disabled = true;
      notifyBtn.textContent = '送信中...';
    }

    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';

    fetch(`/calendar/${window.currentEvent.id}/notify_line`, {
      method: 'POST',
      headers: {
        'X-CSRF-Token': csrfToken,
        'Accept': 'application/json'
      }
    })
    .then(async (response) => {
      const text = await response.text();
      let data;

      try {
        data = JSON.parse(text);
      } catch (_e) {
        data = { error: text || 'サーバーからの応答を解釈できませんでした。' };
      }

      return { ok: response.ok, data };
    })
    .then(({ ok, data }) => {
      if (ok) {
        alert(data.message || 'LINEへ通知を送信しました。');
      } else {
        alert(data.error || 'LINE通知の送信に失敗しました。');
      }
    })
    .catch(error => {
      console.error('Error notifying line:', error);
      alert('通知中にエラーが発生しました: ' + error.message);
    })
    .finally(() => {
      if (notifyBtn) {
        notifyBtn.disabled = false;
        notifyBtn.textContent = 'LINEへ通知';
      }
    });
  };

