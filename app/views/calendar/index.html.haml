      if (intervalSelect && settings.interval) {
        intervalSelect.value = settings.interval.toString();
      }
      
      // 曜日（週次の場合）
      if (settings.days_of_week && Array.isArray(settings.days_of_week)) {
        settings.days_of_week.forEach(day => {
