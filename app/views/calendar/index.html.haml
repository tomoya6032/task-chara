/ TaskChara - カレンダー
= content_for :page_title, "カレンダー"

.px-4.sm:px-6.lg:px-8.py-8
  / カレンダーヘッダー
  .header.bg-white.border-b.border-gray-200.px-2.md:px-6.py-4.rounded-lg.shadow-sm.mb-6
    .flex.items-center.justify-between.flex-wrap.gap-4
      %h1.text-xl.md:text-2xl.font-semibold.text-gray-900.dark:text-white
        📅 カレンダー
      
      .flex.items-center.space-x-2.md:space-x-4.flex-wrap.gap-2
        / 期間ナビゲーション
        .flex.items-center.space-x-2
          - if @view_type == 'week'
            = link_to calendar_index_path(view: 'week', date: (@start_date - 7).to_s),
                class: "nav-btn", title: "前の週" do
              ←
            = link_to calendar_index_path(view: 'week', date: (@start_date + 7).to_s),
                class: "nav-btn", title: "次の週" do
              →
            %span.text-sm.md:text-lg.font-medium.text-gray-900.dark:text-white
              = "#{@start_date.strftime('%Y年%m月%d日')} 〜 #{@end_date.strftime('%m月%d日')}"
          - else
            %button#prev-month.nav-btn{ type: "button" } ←
            %button#next-month.nav-btn{ type: "button" } →
            %span#current-month.text-sm.md:text-lg.font-medium.text-gray-900.dark:text-white
              = @date.strftime("%Y年%m月")
        
        / 表示選択
        .flex.bg-gray-100.dark:bg-slate-700.rounded-md.p-1
          = link_to calendar_index_path(view: 'month', date: @date.to_s),
              class: "view-btn #{@view_type == 'month' ? 'active' : ''}" do
            月
          = link_to calendar_index_path(view: 'week', date: @date.to_s),
              class: "view-btn #{@view_type == 'week' ? 'active' : ''}" do
            週
        
        / イベント作成ボタン
        %button.bg-blue-600.text-white.px-2.md:px-4.py-2.rounded-md.hover:bg-blue-700.transition-colors.text-sm.md:text-base{ onclick: "openNewEventModal()" }
          + 新しいイベント
        
        / 設定ボタン
        = link_to settings_calendar_index_path, 
            class: "bg-gray-600.text-white.px-2.md:px-4.py-2.rounded-md.hover:bg-gray-700.transition-colors.text-sm.md:text-base.flex.items-center" do
          ⚙️ 設定

    / カラーインデックス（凡例）
    .color-legend.mt-4.p-4.bg-gray-50.rounded-lg.border.border-gray-200
      .flex.items-center.justify-between.flex-wrap.gap-2
        %h3.text-sm.font-medium.text-gray-700.mb-2.w-full
          🎨 カテゴリカラー
        .legend-items.flex.flex-wrap.gap-3.w-full
          - @custom_categories.each do |category|
            .legend-item.flex.items-center.space-x-2.text-xs
              .legend-color-box.w-4.h-4.rounded.border.border-gray-300{ style: "background-color: #{category[:color] || category['color']}" }
              %span.text-gray-700.font-medium
                = category[:name] || category['name']

  / カレンダー本体
  .calendar-container.flex-1{ data: { current_date: @date.strftime("%Y-%m-%d") } }
    / 月表示
    #month-view.calendar-view{ class: (@view_type == 'month' ? '' : 'hidden') }
      / 曜日ヘッダー
      .calendar-header-row
        - %w[日 月 火 水 木 金 土].each do |day|
          .calendar-header-cell
            = day
      
      / カレンダーグリッド（完全な格子状レイアウト）
      .calendar-main-grid
        - if @calendar_weeks.present?
          - @calendar_weeks.flatten.each do |day_data|
            .calendar-day-cell{ 
              class: [
                ('calendar-other-month' unless day_data[:current_month]),
                ('calendar-today' if day_data[:today]),
                ('calendar-holiday' if day_data[:holiday]),
                ('calendar-weekend' if day_data[:is_weekend] && @calendar_settings[:show_weekends])
              ].compact.join(' ')
            }
              .calendar-date-header
                = link_to calendar_index_path(view: 'week', date: day_data[:date].to_s),
                    class: "calendar-date-number-link" do
                  .calendar-date-number{ 
                    class: [
                      (day_data[:today] ? 'calendar-today-number' : ''),
                      (day_data[:holiday] ? 'calendar-holiday-number' : '')
                    ].compact.join(' ')
                  }
                    = day_data[:date].day
                - if day_data[:holiday]
                  .calendar-holiday-name.text-xs.text-red-600.font-medium.mt-1
                    = day_data[:holiday].name
              .calendar-events-area
                - if day_data[:events].present?
                  - day_data[:events].each do |event|
                    .calendar-event{ data: { event_id: event.id, event_type: event.event_type }, onclick: "openEventDetailsModal(#{event.id})" }
                      = event.title.truncate(15)
        - else
          .calendar-no-data
            %p データが読み込まれていません

    / 週表示
    #week-view.calendar-view{ class: (@view_type == 'week' ? '' : 'hidden') }
      - if @view_type == 'week' && @week_days.present?
        / 時間列の幅 + 7日分の列
        .week-grid-wrapper
          / 曜日ヘッダー行
          .week-header-row
            .week-time-gutter
            - @week_days.each do |day|
              - is_today = day == Date.current
              - holiday = @holidays.find { |h| h.date == day }
              = link_to calendar_index_path(view: 'week', date: day.to_s),
                  class: "week-header-cell #{is_today ? 'week-header-today' : ''}" do
                .week-header-dow{ class: is_today ? 'text-blue-600 font-bold' : '' }
                  = %w[日 月 火 水 木 金 土][day.wday]
                .week-header-date{ class: is_today ? 'week-date-today-circle' : '' }
                  = day.day
                - if holiday
                  .week-header-holiday= holiday.name

          / 終日イベント行
          .week-allday-row
            .week-allday-gutter
              %span.week-allday-label 終日
            - @week_days.each do |day|
              - is_today = day == Date.current
              .week-allday-cell{ class: is_today ? 'week-allday-cell-today' : '' }
                / 終日イベント
                - allday_ev = @events.select { |e| (e.all_day || e.all_day?) && e.start_time.to_date <= day && e.end_time.to_date >= day }
                - allday_ev.each do |event|
                  .week-allday-event{ data: { event_id: event.id, event_type: event.event_type }, onclick: "event.stopPropagation(); openEventDetailsModal(#{event.id})" }
                    = event.title.truncate(16)
                / 時刻指定の日跨ぎイベントの中間日（開始日・終了日を除く）
                - multiday_ev = @events.select { |e| !e.all_day && !e.all_day? && e.start_time.to_date != e.end_time.to_date && e.start_time.to_date < day && e.end_time.to_date > day }
                - multiday_ev.each do |event|
                  .week-allday-event.week-allday-event-span{ data: { event_id: event.id, event_type: event.event_type }, onclick: "event.stopPropagation(); openEventDetailsModal(#{event.id})" }
                    = "→ #{event.title.truncate(14)}"

          / スクロール可能なタイムライン本体
          .week-body-scroll
            .week-body-inner
              / 時間ラベル列
              .week-time-column
                - (0..23).each do |hour|
                  .week-time-label
                    - if hour.even? && hour > 0
                      = "#{hour}:00"

              / 各日のイベント列
              - @week_days.each do |day|
                - is_today = day == Date.current
                .week-day-column{ class: is_today ? 'week-day-today' : '' }
                  / 時間セル（1時間ごと）
                  - (0..23).each do |hour|
                    .week-hour-cell{ data: { date: day.to_s, hour: hour } }
                  / 時刻指定イベントを絶対配置でオーバーレイ（終日不可、開始日・終了日のみ表示）
                  - day_events = @events.select { |e| !e.all_day && !e.all_day? && (e.start_time.to_date == day || e.end_time.to_date == day) }
                  - event_layouts = day_events.map do |event|
                    - start_hour = event.start_time.to_date == day ? event.start_time.hour + event.start_time.min / 60.0 : 0.0
                    - end_hour = event.end_time.to_date == day ? event.end_time.hour + event.end_time.min / 60.0 : 24.0
                    - { event: event, start_hour: start_hour, end_hour: end_hour, duration: end_hour - start_hour }
                  - event_layouts.sort_by! { |item| [item[:start_hour], -item[:duration], item[:end_hour]] }
                  - active_columns = []
                  - cluster_indices = []
                  - cluster_max_columns = 1
                  - event_layouts.each_with_index do |item, idx|
                    - active_columns.reject! { |active| active[:end_hour] <= item[:start_hour] }
                    - if active_columns.empty? && cluster_indices.any?
                      - cluster_indices.each { |cluster_idx| event_layouts[cluster_idx][:col_count] = cluster_max_columns }
                      - cluster_indices = []
                      - cluster_max_columns = 1
                    
                    - used_cols = active_columns.map { |active| active[:col_index] }
                    - col_index = 0
                    - col_index += 1 while used_cols.include?(col_index)
                    - item[:col_index] = col_index
                    - active_columns << { end_hour: item[:end_hour], col_index: col_index }
                    - cluster_indices << idx
                    - cluster_max_columns = [cluster_max_columns, active_columns.size].max
                  - if cluster_indices.any?
                    - cluster_indices.each { |cluster_idx| event_layouts[cluster_idx][:col_count] = cluster_max_columns }
                  - event_layouts.each do |item|
                    - event = item[:event]
                    - is_multiday = event.start_time.to_date != event.end_time.to_date
                    - start_hour = item[:start_hour]
                    - end_hour = item[:end_hour]
                    - top_pct    = (start_hour / 24.0 * 100).round(2)
                    - height_pct = ((end_hour - start_hour) / 24.0 * 100).round(2)
                    - col_count = [item[:col_count].to_i, 1].max
                    - col_index = item[:col_index].to_i
                    - left_padding_pct = 2.0
                    - right_padding_pct = 1.5
                    - usable_pct = [100.0 - left_padding_pct - right_padding_pct, 35.0].max
                    - if col_count == 1
                      - width_pct = usable_pct.round(4)
                      - left_pct = left_padding_pct.round(4)
                    - else
                      - min_step = 10.0
                      - max_step = 26.0
                      - step_pct = (usable_pct / (col_count + 1.0)).clamp(min_step, max_step)
                      - overlap_multiplier = 2.4
                      - width_pct = [step_pct * overlap_multiplier, usable_pct].min
                      - left_pct = left_padding_pct + (col_index * step_pct)
                      - max_width_from_left = 100.0 - right_padding_pct - left_pct
                      - width_pct = [width_pct, max_width_from_left].min.round(4)
                      - left_pct = left_pct.round(4)
                    
                    - continues_before = is_multiday && event.start_time.to_date != day
                    - continues_after  = is_multiday && event.end_time.to_date != day
                    - compact_class = col_count >= 3 ? 'week-event-compact' : ''
                    - extra_class = "#{continues_before ? 'week-event-continues-before' : ''} #{continues_after ? 'week-event-continues-after' : ''} #{compact_class}".strip
                    - event_z_index = 1 + col_index
                    .week-event-block{ style: "top:#{top_pct}%; height:#{[height_pct, 2].max}%; left:#{left_pct}%; width:#{width_pct}%; z-index:#{event_z_index};", class: extra_class, data: { event_id: event.id, event_type: event.event_type, col_index: col_index, col_count: col_count }, onclick: "event.stopPropagation(); openEventDetailsModal(#{event.id})" }
                      .week-event-title
                        - if continues_before
                          %span.week-event-arrow ↑
                        = event.title.truncate(col_count >= 3 ? 11 : 18)
                        - if continues_after
                          %span.week-event-arrow ↓
                      - if (end_hour - start_hour) >= 1 && !continues_before && col_count <= 2
                        .week-event-time
                          = event.start_time.strftime("%H:%M")
                          = " 〜 "
                          = event.end_time.strftime("%H:%M")
                      - elsif (end_hour - start_hour) >= 1 && continues_before && col_count <= 2
                        .week-event-time
                          = "〜 #{event.end_time.strftime('%H:%M')}"


    / 日表示（非表示）
    #day-view.calendar-view.hidden
      .text-center.text-gray-500.py-8
        日表示は開発中です

  / イベント作成モーダル
  #event-modal.fixed.inset-0.hidden.flex.items-center.justify-center{ style: "background: rgba(0,0,0,0.72); z-index: 9999;" }
    .bg-white.rounded-lg.shadow-lg.p-6.w-96
      %h3.text-lg.font-medium.text-gray-900.mb-4
        新しいイベント

      / エラーメッセージ表示エリア
      #error-messages.hidden.mb-4.p-3.bg-red-100.border.border-red-400.text-red-700.rounded-md

      %form#event-form{ action: "/calendar", method: "post" }
        %input{ type: "hidden", name: "authenticity_token", value: "" }

        .mb-4
          %label.block.text-sm.font-medium.text-gray-700.mb-2
            タイトル
          %input.w-full.border.border-gray-300.rounded-md.px-3.py-2.focus:ring-2.focus:ring-blue-500.focus:border-transparent{ type: "text", name: "event[title]", required: true }

        / 終日トグル
        .mb-3.flex.items-center.gap-2
          %input#event-allday-check{ type: "checkbox", name: "event[all_day]", value: "1",
            onchange: "toggleAlldayMode(this.checked)",
            class: "w-4 h-4 text-blue-600 border-gray-300 rounded" }
          %label{ for: "event-allday-check", class: "text-sm font-medium text-gray-700 cursor-pointer" }
            終日イベント

        / 時刻指定入力（終日チェック時は非表示）
        #event-datetime-fields
          %input{ type: "hidden", id: "event-start-input", name: "event[start_time]" }
          %input{ type: "hidden", id: "event-end-input", name: "event[end_time]" }
          .mb-4
            %label.block.text-sm.font-medium.text-gray-700.mb-1 開始日時
            .flex.items-center.gap-1.flex-wrap
              %input.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ type: "date", id: "event-start-date-part", name: "event[start_date_part]", onchange: "syncDatetimeHidden('event-start-date-part','event-start-hour-part','event-start-min-part','event-start-input')" }
              %select.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ id: "event-start-hour-part", name: "event[start_hour_part]", onchange: "syncDatetimeHidden('event-start-date-part','event-start-hour-part','event-start-min-part','event-start-input')" }
                - (0..23).each do |h|
                  %option{ value: h.to_s.rjust(2,'0') }= "#{h.to_s.rjust(2,'0')}時"
              %select.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ id: "event-start-min-part", name: "event[start_min_part]", onchange: "syncDatetimeHidden('event-start-date-part','event-start-hour-part','event-start-min-part','event-start-input')" }
                - [0, 15, 30, 45].each do |m|
                  %option{ value: m.to_s.rjust(2,'0') }= "#{m.to_s.rjust(2,'0')}分"
          .mb-4
            %label.block.text-sm.font-medium.text-gray-700.mb-1
              終了日時
              %span.text-xs.text-gray-400.ml-1 （別の日付も指定可能）
            .flex.items-center.gap-1.flex-wrap
              %input.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ type: "date", id: "event-end-date-part", name: "event[end_date_part]", onchange: "syncDatetimeHidden('event-end-date-part','event-end-hour-part','event-end-min-part','event-end-input')" }
              %select.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ id: "event-end-hour-part", name: "event[end_hour_part]", onchange: "syncDatetimeHidden('event-end-date-part','event-end-hour-part','event-end-min-part','event-end-input')" }
                - (0..23).each do |h|
                  %option{ value: h.to_s.rjust(2,'0') }= "#{h.to_s.rjust(2,'0')}時"
              %select.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ id: "event-end-min-part", name: "event[end_min_part]", onchange: "syncDatetimeHidden('event-end-date-part','event-end-hour-part','event-end-min-part','event-end-input')" }
                - [0, 15, 30, 45].each do |m|
                  %option{ value: m.to_s.rjust(2,'0') }= "#{m.to_s.rjust(2,'0')}分"

        / 終日用日付入力（終日チェック時のみ表示）
        #event-date-only-fields.hidden
          .mb-4
            %label.block.text-sm.font-medium.text-gray-700.mb-1
              開始日
            %input.w-full.border.border-gray-300.rounded-md.px-3.py-2{ type: "date", id: "event-start-date", name: "event[start_time]" }
          .mb-4
            %label.block.text-sm.font-medium.text-gray-700.mb-1
              終了日
            %input.w-full.border.border-gray-300.rounded-md.px-3.py-2{ type: "date", id: "event-end-date", name: "event[end_time]" }

        .mb-4
          %label.block.text-sm.font-medium.text-gray-700.mb-2
            種類
          %select.w-full.border.border-gray-300.rounded-md.px-3.py-2{ name: "event[event_type]" }
            - @custom_categories.each do |category|
              %option{ value: category[:id] || category['id'] }
                = category[:name] || category['name']

        .mb-6
          %label.block.text-sm.font-medium.text-gray-700.mb-2
            説明
          %textarea.w-full.border.border-gray-300.rounded-md.px-3.py-2.h-20{ name: "event[description]" }

        .flex.justify-end.space-x-3
          %button.bg-gray-200.text-gray-800.px-4.py-2.rounded-md.hover:bg-gray-300.transition-colors{ type: "button", onclick: "closeEventModal()" }
            キャンセル
          %button#submit-btn.bg-blue-600.text-white.px-4.py-2.rounded-md.hover:bg-blue-700.transition-colors{ type: "submit" }
            作成

  / イベント詳細モーダル
  #event-details-modal.fixed.inset-0.bg-black.hidden.flex.items-center.justify-center{ style: "background: rgba(0,0,0,0.72); z-index: 9999;" }
    .bg-white.rounded-lg.shadow-lg.p-6.w-96
      %h3.text-lg.font-medium.text-gray-900.mb-4
        📅 イベント詳細

      #event-details-content
        .space-y-4
          .event-detail-row
            .font-medium.text-gray-700 タイトル:
            .text-gray-900#event-detail-title
          .event-detail-row
            .font-medium.text-gray-700 開始日時:
            .text-gray-900#event-detail-start
          .event-detail-row
            .font-medium.text-gray-700 終了日時:
            .text-gray-900#event-detail-end
          .event-detail-row
            .font-medium.text-gray-700 種類:
            .text-gray-900#event-detail-type
          .event-detail-row
            .font-medium.text-gray-700 説明:
            .text-gray-900#event-detail-description{ style: "white-space: pre-wrap;" }

      .flex.justify-end.space-x-3.mt-6
        %button.bg-gray-200.text-gray-800.px-4.py-2.rounded-md.hover:bg-gray-300.transition-colors{ type: "button", onclick: "closeEventDetailsModal()" }
          閉じる
        %button#notify-event-btn.bg-emerald-600.text-white.px-4.py-2.rounded-md.hover:bg-emerald-700.transition-colors{ type: "button", onclick: "notifyEventToLine()" }
          LINEへ通知
        %button#edit-event-btn.bg-blue-600.text-white.px-4.py-2.rounded-md.hover:bg-blue-700.transition-colors{ type: "button", onclick: "openEditEventModal()" }
          編集
        %button#delete-event-btn.bg-red-600.text-white.px-4.py-2.rounded-md.hover:bg-red-700.transition-colors{ type: "button", onclick: "openDeleteConfirmModal()" }
          削除

  / イベント編集モーダル
  #event-edit-modal.fixed.inset-0.hidden.flex.items-center.justify-center{ style: "background: rgba(0,0,0,0.72); z-index: 9999;" }
    .bg-white.rounded-lg.shadow-lg.p-6.w-96
      %h3.text-lg.font-medium.text-gray-900.mb-4
        ✏️ イベント編集

      / エラーメッセージ表示エリア
      #edit-error-messages.hidden.mb-4.p-3.bg-red-100.border.border-red-400.text-red-700.rounded-md

      %form#event-edit-form{ method: "patch" }
        %input{ type: "hidden", name: "authenticity_token", value: "" }
        %input#edit-event-id{ type: "hidden", name: "id" }

        .mb-4
          %label.block.text-sm.font-medium.text-gray-700.mb-2
            タイトル
          %input#edit-event-title.w-full.border.border-gray-300.rounded-md.px-3.py-2.focus:ring-2.focus:ring-blue-500.focus:border-transparent{ type: "text", name: "event[title]", required: true }

        .mb-4
          %label.block.text-sm.font-medium.text-gray-700.mb-2 開始日時
          %input#edit-event-start{ type: "hidden", name: "event[start_time]" }
          .flex.items-center.gap-1.flex-wrap
            %input.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ type: "date", id: "edit-start-date-part", name: "event[start_date_part]", onchange: "syncDatetimeHidden('edit-start-date-part','edit-start-hour-part','edit-start-min-part','edit-event-start')" }
            %select.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ id: "edit-start-hour-part", name: "event[start_hour_part]", onchange: "syncDatetimeHidden('edit-start-date-part','edit-start-hour-part','edit-start-min-part','edit-event-start')" }
              - (0..23).each do |h|
                %option{ value: h.to_s.rjust(2,'0') }= "#{h.to_s.rjust(2,'0')}時"
            %select.border.border-gray-300.rounded-md.px-2.py-2.text-sm{ id: "edit-start-min-part", name: "event[start_min_part]", onchange: "syncDatetimeHidden('edit-start-date-part','edit-start-hour-part','edit-start-min-part','edit-event-start')" }
              - [0, 15, 30, 45].each do |m|
                %option{ value: m.to_s.rjust(2,'0') }= "#{m.to_s.rjust(2,'0')}分"

        .mb-4
          %label.block.text-sm.font-medium.text-gray-700.mb-2 終了日時
          %input#edit-event-end{ type: "hidden", name: "event[end_time]" }
          .flex.items-center.gap-1.flex-wrap
