  // イベント詳細モーダル
  window.openEventDetailsModal = function(eventId, occurrenceTime) {
    console.log('Opening details for event:', eventId, 'occurrence:', occurrenceTime);
    
    // URLパラメータに開始時刻を追加（繰り返しインスタンスの識別用）
    let url = `/calendar/${eventId}`;
    if (occurrenceTime) {
      url += `?occurrence_time=${encodeURIComponent(occurrenceTime)}`;
    }
    
    fetch(url, {
      headers: {
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      }
    })
    .then(response => {
      if (response.ok) {
        return response.json();
      } else {
        throw new Error('イベント詳細の取得に失敗しました。');
      }
    })
    .then(event => {
      window.currentEvent = event;
      // 繰り返しインスタンスの場合、occurrence_timeを保存
      // サーバーから返された値を優先、なければ引数の値を使用
      if (event.occurrence_time) {
        window.currentEvent.occurrence_time = event.occurrence_time;
      } else if (occurrenceTime) {
        window.currentEvent.occurrence_time = occurrenceTime;
      }
      
      console.log('Event loaded:', event.id, 'recurring:', event.recurring, 'occurrence_time:', window.currentEvent.occurrence_time);
      
      // 詳細情報を表示
      const titleEl = document.getElementById('event-detail-title');
      const startEl = document.getElementById('event-detail-start');
      const endEl = document.getElementById('event-detail-end');
      const typeEl = document.getElementById('event-detail-type');
      const descEl = document.getElementById('event-detail-description');
      
      if (titleEl) titleEl.textContent = event.title || '';
      if (startEl) startEl.textContent = formatDateTime(event.start_time);
      if (endEl) endEl.textContent = formatDateTime(event.end_time);
      if (typeEl) typeEl.textContent = getEventTypeLabel(event.event_type);
      if (descEl) descEl.textContent = event.description || '説明なし';
      const reminderEl = document.getElementById('event-detail-reminder');
      if (reminderEl) {
        const reminderLabels = { 30: '30分前', 60: '1時間前', 180: '3時間前', 1440: '1日前', 4320: '3日前' };
        reminderEl.textContent = event.reminder_minutes != null ? (reminderLabels[event.reminder_minutes] || event.reminder_minutes + '分前') : '通知なし';
      }
      
      // 繰り返し設定を表示
      const recurringEl = document.getElementById('event-detail-recurring');
      if (recurringEl) {
        if (event.recurring || event.recurring_event_id) {
          let recurringText = '繰り返しイベント';
          
          if (event.recurrence_settings) {
            const settings = event.recurrence_settings;
            const frequencyLabels = { daily: '毎日', weekly: '毎週', monthly: '毎月' };
            recurringText = frequencyLabels[settings.frequency] || settings.frequency;
            
            if (settings.interval > 1) {
              recurringText += ` (${settings.interval}回ごと)`;
            }
            
            if (settings.days_of_week && settings.days_of_week.length > 0) {
              const dayLabels = { 
                monday: '月', tuesday: '火', wednesday: '水', thursday: '木', 
                friday: '金', saturday: '土', sunday: '日' 
              };
              const days = settings.days_of_week.map(d => dayLabels[d]).join(', ');
              recurringText += ` (${days})`;
            }
            
            if (settings.end_type === 'date' && settings.end_date) {
              recurringText += ` 〜 ${settings.end_date}`;
            } else if (settings.end_type === 'count' && settings.count) {
              recurringText += ` (${settings.count}回)`;
            }
          }
          
          if (event.occurrence_time) {
            recurringText += ' [このコマのみ]';
          } else if (event.recurring_event_id) {
            recurringText += ' [子イベント]';
          } else if (event.recurring) {
            recurringText += ' [親イベント]';
          }
          
          recurringEl.textContent = recurringText;
        } else {
          recurringEl.textContent = 'なし';
        }
      }
      
      // モーダルを表示
      const modal = document.getElementById('event-details-modal');
      if (modal) {
        modal.classList.remove('hidden');
      }
    })
    .catch(error => {
      console.error('Error fetching event details:', error);
      alert('エラーが発生しました: ' + error.message);
    });
  };

