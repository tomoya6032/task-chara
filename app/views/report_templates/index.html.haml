/ 報告書テンプレート一覧ページ
= content_for :page_title, "テンプレート管理"

.px-4.sm:px-6.lg:px-8.py-8
  / ヘッダー
  .flex.items-center.justify-between.mb-8
    %div
      %h1.text-3xl.font-bold.text-slate-900.dark:text-white
        📄 報告書テンプレート管理
      %p.mt-2.text-slate-600.dark:text-slate-400
        PDFファイルから報告書テンプレートを作成・管理
    = link_to new_report_template_path, 
        class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors shadow-sm" do
      ➕ 新しいテンプレートを作成

  / ユーザーテンプレート
  - if @user_templates.any?
    .mb-8
      %h2.text-lg.font-semibold.text-slate-800.dark:text-slate-200.mb-4 マイテンプレート
      .grid.gap-6
        - @user_templates.each do |template|
          .bg-white.dark:bg-slate-800.shadow-md.rounded-xl.border.border-slate-200.dark:border-slate-700.overflow-hidden.hover:shadow-lg.transition-shadow
            .p-6
              .flex.items-start.justify-between.mb-3
                %h3.font-medium.text-slate-900.dark:text-white= template.name
                - if template.is_default?
                  %span.bg-blue-100.dark:bg-blue-900.text-blue-800.dark:text-blue-200.text-xs.px-2.py-1.rounded-full デフォルト
              
              - if template.description.present?
                %p.text-sm.text-slate-600.dark:text-slate-400.mb-3= truncate(template.description, length: 100)
              
              .flex.items-center.text-xs.text-slate-500.dark:text-slate-400.mb-4
                %span.mr-4
                  📁 #{template.pdf_file_name}
                - if template.pdf_file_size
                  %span #{number_to_human_size(template.pdf_file_size)}
              
              .flex.justify-between.items-center
                .flex.space-x-2
                  = link_to template, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium" do
                    詳細
                  = link_to edit_report_template_path(template), class: "text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 text-sm font-medium" do
                    編集
                
                .flex.space-x-1
                  = link_to analyze_report_template_path(template), method: :post, class: "text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 text-sm font-medium" do
                    🔄 再解析
                  = link_to template, method: :delete, data: { confirm: "本当に削除しますか？" }, class: "text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 text-sm font-medium" do
                    🗑️

  / システムテンプレート
  - if @system_templates.any?
    .mb-8
      %h2.text-lg.font-semibold.text-slate-800.dark:text-slate-200.mb-4 システムテンプレート
      .grid.gap-6
        - @system_templates.each do |template|
          .bg-slate-50.dark:bg-slate-700.rounded-xl.border.border-slate-200.dark:border-slate-600.overflow-hidden.hover:shadow-lg.transition-shadow
            .p-6
              .flex.items-start.justify-between.mb-3
                %h3.font-medium.text-slate-900.dark:text-white= template.name
                %span.bg-slate-200.dark:bg-slate-600.text-slate-600.dark:text-slate-300.text-xs.px-2.py-1.rounded-full システム
              
              - if template.description.present?
                %p.text-sm.text-slate-600.dark:text-slate-400.mb-3= truncate(template.description, length: 100)
              
              .flex.items-center.text-xs.text-slate-500.dark:text-slate-400.mb-4
                %span.mr-4
                  📁 #{template.pdf_file_name}
                - if template.pdf_file_size
                  %span #{number_to_human_size(template.pdf_file_size)}
              
              .text-right
                = link_to template, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium" do
                  詳細を見る

  / 空の状態
  - if @user_templates.empty? && @system_templates.empty?
    .text-center.py-12
      .text-slate-400.dark:text-slate-500.text-6xl.mb-4 📄
      %h3.text-lg.font-medium.text-slate-900.dark:text-white.mb-2 テンプレートがありません
      %p.text-slate-600.dark:text-slate-400.mb-6 
        PDFファイルをアップロードして、独自の報告書テンプレートを作成しましょう
      = link_to new_report_template_path, 
          class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors shadow-sm" do
        ➕ 最初のテンプレートを作成