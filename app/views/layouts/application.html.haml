!!!
%html
  %head
    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title= content_for(:title) || "Task Character"
    %meta{:content => "width=device-width,initial-scale=1", :name => "viewport"}/
    %meta{:content => "yes", :name => "apple-mobile-web-app-capable"}/
    %meta{:content => "yes", :name => "mobile-web-app-capable"}/
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head
    %link{:href => "/icon.png", :rel => "icon", :type => "image/png"}/
    %link{:href => "/icon.svg", :rel => "icon", :type => "image/svg+xml"}/
    %link{:href => "/icon.png", :rel => "apple-touch-icon"}/
    = stylesheet_link_tag "tailwind", "data-turbo-track": "reload"
    = stylesheet_link_tag :app, "data-turbo-track": "reload"
    = javascript_importmap_tags
  %body.bg-slate-50.dark:bg-slate-900
    = render 'shared/header'
    
    / サイドバーナビゲーション
    = render 'shared/navigation'
    
    / メインコンテンツエリア
    .lg:pl-72.pt-16
      = yield
      
    / フローティングアクションボタン（モバイル用）
    .fixed.bottom-20.right-4.lg:hidden.z-40
      = link_to new_activity_path, 
          class: "bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-full w-14 h-14 flex items-center justify-center shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-200",
          data: { "turbo-frame": "activity_form_modal" } do
        %span.text-xl 📝
    
    / モーダルエリア
    %turbo-frame#task-modal
    %turbo-frame#activity_form_modal
