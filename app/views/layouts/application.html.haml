!!!
%html
  %head
    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title= content_for(:title) || "Task Character"
    %meta{:content => "width=device-width,initial-scale=1", :name => "viewport"}/
    %meta{:content => "yes", :name => "apple-mobile-web-app-capable"}/
    %meta{:content => "yes", :name => "mobile-web-app-capable"}/
    / 会員制サイトのため検索エンジンのインデックスを禁止
    %meta{:name => "robots", :content => "noindex, nofollow, noarchive"}/
    %meta{:name => "googlebot", :content => "noindex, nofollow"}/
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head
    / PWA Manifest
    %link{:rel => "manifest", :href => "/manifest.json"}/
    / アイコン設定（ブラウザタブ用favicon）
    %link{:href => "/favicon.ico", :rel => "icon", :type => "image/x-icon"}/
    %link{:href => "/icon-192.png", :rel => "icon", :type => "image/png", :sizes => "192x192"}/
    %link{:href => "/icon-512.png", :rel => "icon", :type => "image/png", :sizes => "512x512"}/
    / Apple Touch Icons
    %link{:href => "/icon-192.png", :rel => "apple-touch-icon", :sizes => "192x192"}/
    %link{:href => "/icon-512.png", :rel => "apple-touch-icon", :sizes => "512x512"}/
    = stylesheet_link_tag "tailwind", "data-turbo-track": "reload"
    = stylesheet_link_tag :app, "data-turbo-track": "reload"
    = javascript_importmap_tags
  %body.bg-slate-50.dark:bg-slate-900
    = render 'shared/header'
    
    / サイドバーナビゲーション
    = render 'shared/navigation'
    
    / メインコンテンツエリア
    - if user_signed_in?
      .lg:pl-72.pt-16
        - if flash[:notice]
          .bg-green-100.border.border-green-400.text-green-700.px-4.py-3.rounded.mx-4.mt-4{role: "alert"}
            = flash[:notice]
        - if flash[:alert]
          .bg-red-100.border.border-red-400.text-red-700.px-4.py-3.rounded.mx-4.mt-4{role: "alert"}
            = flash[:alert]
        = yield
    - else
      .pt-16
        - if flash[:notice]
          .bg-green-100.border.border-green-400.text-green-700.px-4.py-3.rounded.mx-4.mt-4{role: "alert"}
            = flash[:notice]
        - if flash[:alert]
          .bg-red-100.border.border-red-400.text-red-700.px-4.py-3.rounded.mx-4.mt-4{role: "alert"}
            = flash[:alert]
        = yield
      
    / モーダルエリア
    %turbo-frame#task-modal
    %turbo-frame#activity_form_modal
