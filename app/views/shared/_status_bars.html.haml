/ app/views/shared/_status_bars.html.haml
.bg-white.dark:bg-slate-800.overflow-hidden.shadow-xl.rounded-2xl.mb-8
  .px-4.py-6.sm:px-6.lg:px-8
    %h3.text-lg.font-semibold.text-slate-900.dark:text-white.mb-6
      キャラクターステータス

    .space-y-6
      / 内面の磨き
      .status-bar
        .flex.justify-between.items-center.mb-3
          .flex.items-center.gap-2
            %span.text-2xl 🧘‍♂️
            %span.text-sm.font-medium.text-slate-700.dark:text-slate-300 内面の磨き
          %span.text-sm.font-bold.text-slate-500.dark:text-slate-400= "#{character.inner_peace}/100"
        .w-full.bg-slate-200.dark:bg-slate-700.rounded-full.h-3.overflow-hidden
          .h-3.rounded-full.transition-all.duration-1000.ease-out.bg-gradient-to-r.from-purple-400.to-pink-500{
            style: "width: #{character.inner_peace}%",
            data: { animate: "progress" }
          }

      / 知力
      .status-bar
        .flex.justify-between.items-center.mb-3
          .flex.items-center.gap-2
            %span.text-2xl 🧠
            %span.text-sm.font-medium.text-slate-700.dark:text-slate-300 知力
          %span.text-sm.font-bold.text-slate-500.dark:text-slate-400= "#{character.intelligence}/100"
        .w-full.bg-slate-200.dark:bg-slate-700.rounded-full.h-3.overflow-hidden
          .h-3.rounded-full.transition-all.duration-1000.ease-out.bg-gradient-to-r.from-blue-400.to-cyan-500{
            style: "width: #{character.intelligence}%",
            data: { animate: "progress" }
          }

      / 精神的強靭さ
      .status-bar
        .flex.justify-between.items-center.mb-3
          .flex.items-center.gap-2
            %span.text-2xl 💪
            %span.text-sm.font-medium.text-slate-700.dark:text-slate-300 精神的強靭さ
          %span.text-sm.font-bold.text-slate-500.dark:text-slate-400= "#{character.toughness}/100"
        .w-full.bg-slate-200.dark:bg-slate-700.rounded-full.h-3.overflow-hidden
          .h-3.rounded-full.transition-all.duration-1000.ease-out.bg-gradient-to-r.from-green-400.to-emerald-500{
            style: "width: #{character.toughness}%",
            data: { animate: "progress" }
          }

      / ネガティブステータス（だらしなさ）
      .status-bar
        .flex.justify-between.items-center.mb-3
          .flex.items-center.gap-2
            %span.text-2xl 😴
            %span.text-sm.font-medium.text-slate-700.dark:text-slate-300 だらしなさ
          %span.text-sm.font-bold.text-slate-500.dark:text-slate-400= "#{character.disheveled_level.round(1)}/100"
        .w-full.bg-slate-200.dark:bg-slate-700.rounded-full.h-3.overflow-hidden
          .h-3.rounded-full.transition-all.duration-1000.ease-out.bg-gradient-to-r.from-red-400.to-orange-500{
            style: "width: #{character.disheveled_level}%",
            data: { animate: "progress" }
          }