/ app/views/shared/_flash.html.haml
- type = local_assigns[:type] || "notice"
- message = local_assigns[:message] || ""
- flash_colors = {"success" => "bg-green-50 border-green-200 text-green-800 dark:bg-green-900 dark:border-green-700 dark:text-green-300", "error" => "bg-red-50 border-red-200 text-red-800 dark:bg-red-900 dark:border-red-700 dark:text-red-300", "notice" => "bg-blue-50 border-blue-200 text-blue-800 dark:bg-blue-900 dark:border-blue-700 dark:text-blue-300", "alert" => "bg-yellow-50 border-yellow-200 text-yellow-800 dark:bg-yellow-900 dark:border-yellow-700 dark:text-yellow-300"}
- flash_icons = {"success" => "✅", "error" => "❌", "notice" => "ℹ️", "alert" => "⚠️"}

.flash-message.border.rounded-lg.p-4.mb-4.animate-fade-in{class: flash_colors[type] || flash_colors["notice"], data: { controller: "flash", flash_timeout_value: 5000 }}
  .flex.items-center.justify-between
    .flex.items-center.gap-2
      %span.text-lg= flash_icons[type] || flash_icons["notice"]
      %span.text-sm.font-medium= message
    %button.text-lg.opacity-70.hover:opacity-100.transition-opacity{data: { action: "click->flash#close" }} ×