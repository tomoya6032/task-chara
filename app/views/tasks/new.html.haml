/ app/views/tasks/new.html.haml
%turbo-frame#modal
  .fixed.inset-0.bg-black.bg-opacity-50.z-50.flex.items-center.justify-center.p-4{
    data: { controller: "modal", action: "click->modal#closeOnBackdrop" }
  }
    .bg-white.dark:bg-slate-800.rounded-2xl.shadow-2xl.max-w-lg.w-full{
      class: "max-h-[90vh] overflow-y-auto",
      data: { modal_target: "content" }
    }
      / ヘッダー
      .flex.items-center.justify-between.p-6.border-b.border-slate-200.dark:border-slate-600
        %h2.text-xl.font-bold.text-slate-900.dark:text-white
          ✅ 新しいタスクを追加
        %button.text-slate-400.hover:text-slate-600.dark:hover:text-slate-300.text-2xl.leading-none{
          data: { action: "click->modal#close" }
        } ×

      / フォーム
      = form_with model: @task, 
          url: tasks_path, 
          local: false,
          class: "p-6" do |form|
        
        .mb-6
          = form.label :title, "タスク名", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
          = form.text_field :title, 
              placeholder: "例：利用者Bさんの訪問介護",
              class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500"
        
        .mb-6
          = form.label :category, "カテゴリ", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
          = form.select :category, 
            options_for_select([
              ['訪問福祉 🏠', 'welfare'],
              ['Web制作 💻', 'web'],
              ['事務作業 📋', 'admin']
            ], @task.category),
            {},
            { class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500" }
        
        .mb-6
          = form.label :dislike_level, "嫌い度（1-10）", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
          %div.text-xs.text-slate-500.dark:text-slate-400.mb-2
            ※ 嫌いなタスクほど完了時の強靭さボーナスが大きくなります
          = form.range_field :dislike_level, 
              min: 1, max: 10, value: @task.dislike_level || 5,
              class: "w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer dark:bg-slate-700",
              data: { controller: "range-slider", action: "input->range-slider#update" }
          .flex.justify-between.items-center.mt-2
            %span.text-xs.text-slate-500 😊 普通
            %span.text-sm.font-medium.text-slate-700.dark:text-slate-300{
              data: { range_slider_target: "display" }
            } 5
            %span.text-xs.text-slate-500 😱 大嫌い

        / ボタン
        .flex.gap-3
          %button.flex-1.bg-slate-200.dark:bg-slate-600.text-slate-700.dark:text-slate-300.font-medium.py-3.px-4.rounded-lg.hover:bg-slate-300.dark:hover:bg-slate-500.transition-colors{
            type: "button",
            data: { action: "click->modal#close" }
          }
            キャンセル
          
          = form.submit "タスクを追加", 
              class: "flex-1 bg-gradient-to-r from-green-500 to-blue-600 text-white font-medium py-3 px-4 rounded-lg hover:from-green-600 hover:to-blue-700 transition-all transform hover:scale-105 shadow-lg"