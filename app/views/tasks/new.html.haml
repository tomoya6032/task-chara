- if params[:from_new_window] == 'true'
  / 別ウィンドウでの表示（Turbo Frameなし）
  !!!
  %html
    %head
      %meta{charset: "utf-8"}
      %meta{name: "viewport", content: "width=device-width,initial-scale=1"}
      %title TaskChara - 新しいタスクを追加
      = csrf_meta_tags
      = csp_meta_tag
      = stylesheet_link_tag "application", "data-turbo-track": "reload"
      = javascript_importmap_tags

    %body.bg-gradient-to-br.from-blue-50.to-purple-50.min-h-screen.flex.items-center.justify-center.p-4
      .bg-white.rounded-2xl.shadow-xl.max-w-lg.w-full{style: "max-height: 90vh; overflow-y: auto;"}
        / ヘッダー
        .flex.items-center.justify-between.p-6.border-b.border-slate-200.dark:border-slate-600
          %h2.text-xl.font-bold.text-slate-900.dark:text-white
            ✅ 新しいタスクを追加
          %button.text-slate-400.hover:text-slate-600.dark:hover:text-slate-300.text-2xl.leading-none{
            onclick: "window.close()"
          } ×

        / フォーム
        = form_with model: @task, 
          url: tasks_path, 
          local: true,
          data: { turbo: false },
          class: "p-6" do |form|
          
          = form.hidden_field :from_new_window, value: 'true'
          
          .mb-6
            = form.label :title, "タスク名", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
            = form.text_field :title, 
              placeholder: "例：利用者Bさんの訪問介護",
              class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500"
          
          .mb-6
            = form.label :category, "カテゴリ", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
            = form.select :category, options_for_select([['訪問福祉 🏠', 'welfare'], ['Web制作 💻', 'web'], ['事務作業 📋', 'admin']], @task.category), {}, class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500"
          
          .mb-6
            = form.label :due_date, "期限", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
            %div.text-xs.text-slate-500.dark:text-slate-400.mb-2
              ※ 年月日と時間を設定してください（未設定も可能）
            = form.datetime_local_field :due_date, 
              class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500"
          
          .mb-6
            = form.label :dislike_level, "嫌い度（1-10）", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
            %div.text-xs.text-slate-500.dark:text-slate-400.mb-2
              ※ 嫌いなタスクほど完了時の強靽さボーナスが大きくなります
            = form.range_field :dislike_level, 
              min: 1, max: 10, value: @task.dislike_level || 5,
              class: "w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer dark:bg-slate-700",
              data: { controller: "range-slider", action: "input->range-slider#update" }
            .flex.justify-between.items-center.mt-2
              %span.text-xs.text-slate-500 😊 普通
              %span.text-sm.font-medium.text-slate-700.dark:text-slate-300{
                data: { "range-slider-target": "display" }
              } 5
              %span.text-xs.text-slate-500 😱 大嫌い

          / ボタン
          .flex.gap-3
            %button.flex-1.bg-slate-200.dark:bg-slate-600.text-slate-700.dark:text-slate-300.font-medium.py-3.px-4.rounded-lg.hover:bg-slate-300.dark:hover:bg-slate-500.transition-colors{
              type: "button",
              onclick: "window.close()"
            }
              キャンセル
            
            = form.submit "タスクを追加", 
              class: "flex-1 bg-gradient-to-r from-green-500 to-blue-600 text-white font-medium py-3 px-4 rounded-lg hover:from-green-600 hover:to-blue-700 transition-all transform hover:scale-105 shadow-lg"

- else
  / 通常のモーダル表示（Turbo Frame使用）
  %turbo-frame#task-modal
    .fixed.inset-0.bg-black.bg-opacity-30.backdrop-blur-sm.z-50.flex.items-center.justify-center.p-4.pb-20.lg:pb-4{
      data: { controller: "modal", action: "click->modal#closeOnBackdrop" }
    }
      .bg-white.dark:bg-slate-800.bg-opacity-95.dark:bg-opacity-95.rounded-2xl.shadow-2xl.max-w-lg.w-full.border.border-slate-200.dark:border-slate-600{
        style: "max-height: calc(100vh - 8rem); overflow-y: auto;",
        data: { modal_target: "content" }
      }
        / ヘッダー
        .flex.items-center.justify-between.p-6.border-b.border-slate-200.dark:border-slate-600
          %h2.text-xl.font-bold.text-slate-900.dark:text-white
            ✅ 新しいタスクを追加
          = link_to root_path, class: "text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 text-2xl leading-none", data: { turbo_frame: "_top" } do
            ×

        / フォーム
        = form_with model: @task, 
          url: tasks_path, 
          local: true,
          data: { turbo: false },
          class: "p-6 pb-0" do |form|
          
          - if params[:from_new_window] == 'true'
            = form.hidden_field :from_new_window, value: 'true'
          
          .mb-6
            = form.label :title, "タスク名", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
            = form.text_field :title, 
              placeholder: "例：利用者Bさんの訪問介護",
              class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500"
          
          .mb-6
            = form.label :category, "カテゴリ", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
            = form.select :category, options_for_select([['訪問福祉 🏠', 'welfare'], ['Web制作 💻', 'web'], ['事務作業 📋', 'admin']], @task.category), {}, class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500"
          
          .mb-6
            = form.label :due_date, "期限", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
            %div.text-xs.text-slate-500.dark:text-slate-400.mb-2
              ※ 年月日と時間を設定してください（未設定も可能）
            = form.datetime_local_field :due_date, 
              class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500"
          
          .mb-6
            = form.label :dislike_level, "嫌い度（1-10）", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
            %div.text-xs.text-slate-500.dark:text-slate-400.mb-2
              ※ 嫌いなタスクほど完了時の強靽さボーナスが大きくなります
            = form.range_field :dislike_level, 
              min: 1, max: 10, value: @task.dislike_level || 5,
              class: "w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer dark:bg-slate-700",
              data: { controller: "range-slider", action: "input->range-slider#update" }
            .flex.justify-between.items-center.mt-2
              %span.text-xs.text-slate-500 😊 普通
              %span.text-sm.font-medium.text-slate-700.dark:text-slate-300{
                data: { "range-slider-target": "display" }
              } 5
              %span.text-xs.text-slate-500 😱 大嫌い

          / ボタン
          .flex.flex-col.sm:flex-row.gap-3.pt-4.border-t.border-slate-200.dark:border-slate-600.bg-slate-50.dark:bg-slate-800.px-6.py-4.rounded-b-2xl.mt-4
            = link_to root_path, class: "w-full sm:flex-1 bg-slate-200 dark:bg-slate-600 text-slate-700 dark:text-slate-300 font-medium py-6 px-4 rounded-lg hover:bg-slate-300 dark:hover:bg-slate-500 transition-colors text-center", data: { turbo_frame: "_top" } do
              キャンセル
            
            = form.submit "タスクを追加", 
              class: "w-full sm:flex-1 bg-gradient-to-r from-green-500 to-blue-600 text-white font-medium py-6 px-4 rounded-lg hover:from-green-600 hover:to-blue-700 transition-all transform hover:scale-105 shadow-lg"