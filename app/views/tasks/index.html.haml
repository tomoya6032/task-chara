/ app/views/tasks/index.html.haml
%html{lang: "ja"}
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1.0"}
    %title タスク一覧 - TaskChara
    = csrf_meta_tags
    = csp_meta_tag
    = stylesheet_link_tag "tailwind"
    = javascript_importmap_tags

  %body.bg-slate-50.dark:bg-slate-900.min-h-screen
    / フラッシュメッセージ表示領域（画面中央）
    #flash-container.fixed.inset-0.flex.items-start.justify-center.pt-20.z-50.pointer-events-none
      - flash.each do |type, message|
        .flash-message.border.rounded-xl.p-6.mb-4.animate-bounce.bg-white.border-green-300.text-green-800.shadow-2xl.max-w-md.mx-4.pointer-events-auto{
          data: { controller: "flash", flash_timeout_value: 8000 }
        }
          .flex.items-center.justify-between
            .flex.items-center.gap-3
              %span.text-2xl 🎉
              .text-left
                %div.text-lg.font-bold お疲れさま！
                %div.text-sm= message
            %button.text-lg.opacity-70.hover:opacity-100.transition-opacity.ml-4{
              data: { action: "click->flash#close" }
            } ×

    .max-w-4xl.mx-auto.px-4.py-6

      / ヘッダー
      .flex.items-center.justify-between.mb-6
        .flex.items-center.gap-3
          = link_to dashboard_path, class: "text-slate-600 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200" do
            %svg.w-6.h-6{fill: "none", stroke: "currentColor", viewbox: "0 0 24 24"}
              %path{d: "M15 19l-7-7 7-7", "stroke-linecap": "round", "stroke-linejoin": "round", "stroke-width": "2"}
          %h1.text-2xl.font-bold.text-slate-900.dark:text-white
            📋 全タスク一覧

        .flex.gap-2
          = link_to completed_tasks_path, class: "bg-green-200 dark:bg-green-800 text-green-800 dark:text-green-200 px-4 py-2 rounded-lg hover:bg-green-300 dark:hover:bg-green-700 transition-colors" do
            ✅ 完了済み
          = link_to hidden_tasks_path, class: "bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors" do
            👁️ 非表示

      / 統計情報
      .bg-white.dark:bg-slate-800.rounded-xl.shadow-sm.p-6.mb-6
        .grid.grid-cols-1.sm:grid-cols-3.gap-4
          .text-center
            .text-2xl.font-bold.text-blue-600.dark:text-blue-400
              = @pending_tasks.count
            .text-sm.text-slate-600.dark:text-slate-400
              未完了タスク

          .text-center
            .text-2xl.font-bold.text-green-600.dark:text-green-400
              = @completed_tasks.count
            .text-sm.text-slate-600.dark:text-slate-400
              完了済みタスク

          .text-center
            .text-2xl.font-bold.text-slate-600.dark:text-slate-400
              = @hidden_tasks.count
            .text-sm.text-slate-600.dark:text-slate-400
              非表示タスク

      / タブナビゲーション
      .bg-white.dark:bg-slate-800.rounded-xl.shadow-sm.overflow-hidden.mb-6
        .flex.border-b.border-slate-200.dark:border-slate-600
          %button.flex-1.py-3.px-4.text-center.font-medium.transition-colors{
            class: "bg-blue-50 dark:bg-blue-900 text-blue-600 dark:text-blue-400 border-b-2 border-blue-600",
            onclick: "showTab('pending')"
          }
            未完了 (#{@pending_tasks.count})
          %button.flex-1.py-3.px-4.text-center.font-medium.text-slate-600.dark:text-slate-400.hover:bg-slate-50.dark:hover:bg-slate-700.transition-colors{
            onclick: "showTab('completed')"
          }
            完了済み (#{@completed_tasks.count})

        / 未完了タスク
        #pending-tab.p-6
          - if @pending_tasks.any?
            .space-y-4
              - @pending_tasks.each do |task|
                .bg-slate-50.dark:bg-slate-700.rounded-lg.p-4.border.border-slate-200.dark:border-slate-600
                  .flex.items-center.justify-between
                    .flex.items-center.gap-3
                      / カテゴリアイコン
                      - case task.category
                      - when 'welfare'
                        %span.text-xl 🏠
                      - when 'web'
                        %span.text-xl 💻
                      - when 'admin'
                        %span.text-xl 📋
                      - else
                        %span.text-xl ✅

                      .flex-1
                        %h4.font-medium.text-slate-900.dark:text-white
                          = task.title
                        .text-sm.text-slate-600.dark:text-slate-400.mt-1
                          嫌い度: #{task.dislike_level}/10 | 
                          作成: #{task.created_at.strftime("%m/%d %H:%M")}

                    .flex.gap-2
                      = button_to complete_task_path(task), method: :patch, class: "bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded text-sm transition-colors", data: { confirm: "「#{task.title}」を完了しますか？\n強靭さ+#{(task.dislike_level || 1) * 1.5}pt獲得できます！", turbo: false }, form_class: "inline" do
                        🎯 完了
                      = button_to hide_task_path(task), method: :patch, class: "bg-slate-600 hover:bg-slate-700 text-white px-3 py-1 rounded text-sm transition-colors", data: { turbo: false }, form_class: "inline" do
                        👁️ 非表示
          - else
            .text-center.py-8
              .text-4xl.mb-2 🎉
              %p.text-slate-600.dark:text-slate-400
                すべてのタスクが完了しています！

        / 完了済みタスク
        #completed-tab.p-6.hidden
          - if @completed_tasks.any?
            .space-y-4
              - @completed_tasks.limit(10).each do |task|
                .bg-green-50.dark:bg-green-900.rounded-lg.p-4.border.border-green-200.dark:border-green-700
                  .flex.items-center.gap-3
                    %span.text-xl ✅
                    .flex-1
                      %h4.font-medium.text-slate-900.dark:text-white
                        = task.title
                      .text-sm.text-green-600.dark:text-green-400.mt-1
                        完了: #{task.completed_at.strftime("%m/%d %H:%M")} | 
                        獲得強靭さ: +#{(task.dislike_level || 1) * 1.5}pt
            
            - if @completed_tasks.count > 10
              .text-center.mt-6
                = link_to completed_tasks_path, class: "text-blue-600 dark:text-blue-400 hover:underline" do
                  すべての完了タスクを見る (#{@completed_tasks.count}件)
          - else
            .text-center.py-8
              .text-4xl.mb-2 🎯
              %p.text-slate-600.dark:text-slate-400
                まだ完了したタスクがありません

    :javascript
      // フラッシュメッセージの自動非表示
      document.addEventListener('DOMContentLoaded', function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
          setTimeout(function() {
            message.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out';
            message.style.opacity = '0';
            message.style.transform = 'translateY(-20px)';
            setTimeout(function() {
              if (message.parentNode) {
                message.parentNode.removeChild(message);
              }
            }, 500);
          }, 8000);
        });
      });

      function showTab(tabName) {
        // すべてのタブを非表示
        document.getElementById('pending-tab').classList.add('hidden');
        document.getElementById('completed-tab').classList.add('hidden');
        
        // すべてのボタンのアクティブ状態をリセット
        const buttons = document.querySelectorAll('.flex-1');
        buttons.forEach(btn => {
          btn.className = 'flex-1 py-3 px-4 text-center font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors';
        });
        
        // 選択されたタブを表示
        document.getElementById(tabName + '-tab').classList.remove('hidden');
        
        // 選択されたボタンをアクティブに
        event.target.className = 'flex-1 py-3 px-4 text-center font-medium bg-blue-50 dark:bg-blue-900 text-blue-600 dark:text-blue-400 border-b-2 border-blue-600 transition-colors';
      }