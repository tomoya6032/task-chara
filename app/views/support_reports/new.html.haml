/ 支援報告書新規作成ページ
.min-h-screen.bg-slate-50.dark:bg-slate-900
  / デスクトップサイドバー（lg以上で表示）
  .hidden.lg:fixed.lg:inset-y-0.lg:z-50.lg:flex.lg:w-72.lg:flex-col
    .flex.grow.flex-col.gap-y-5.overflow-y-auto.bg-white.dark:bg-slate-800.px-6.border-r.border-slate-200.dark:border-slate-700
      .flex.h-16.shrink-0.items-center
        %h1.text-lg.font-semibold.text-slate-900.dark:text-white
          TaskChara
        %span.ml-2.text-xs.text-slate-500 ✨

      %nav.flex.flex-1.flex-col
        %ul.flex.flex-1.flex-col.gap-y-7{role: "list"}
          %li
            %ul.space-y-1{role: "list"}
              %li
                = link_to dashboard_path, class: "text-slate-400 hover:text-slate-700 hover:bg-slate-50 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold" do
                  📊
                  ダッシュボード
              %li
                = link_to activities_path, class: "text-slate-400 hover:text-slate-700 hover:bg-slate-50 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold" do
                  = "📖"
                  日報一覧
              %li
                = link_to support_reports_path, class: "bg-slate-50 text-slate-700 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold" do
                  = "📋"
                  支援報告書
              %li
                = link_to report_templates_path, class: "text-slate-400 hover:text-slate-700 hover:bg-slate-50 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold" do
                  = "📄"
                  テンプレート管理

  / メインコンテンツエリア
  .lg:pl-72.pt-4
    .px-4.sm:px-6.lg:px-8.py-8
      / 戻るボタン
      .mb-6
        = link_to support_reports_path, class: "inline-flex items-center text-sm text-slate-500 hover:text-slate-700" do
          ← 支援報告書一覧に戻る

      / フォームカード
      .max-w-2xl
        .bg-white.dark:bg-slate-800.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700.overflow-hidden
          .px-6.py-6.border-b.border-slate-200.dark:border-slate-700
            %h1.text-2xl.font-bold.text-slate-900.dark:text-white
              📋 支援報告書の新規作成
            %p.mt-2.text-slate-600.dark:text-slate-400
              期間を指定してAIが日報データから支援報告書を生成します

          = form_with model: @support_report, local: true, class: "px-6 py-6" do |f|
            - if @support_report.errors.any?
              .mb-6.bg-red-50.border.border-red-200.rounded-lg.p-4
                %h3.text-sm.font-medium.text-red-800.mb-2
                  入力内容に問題があります：
                %ul.text-sm.text-red-700.space-y-1
                  - @support_report.errors.full_messages.each do |message|
                    %li= message

            .space-y-6
              / タイトル
              %div
                = f.label :title, "タイトル", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = f.text_field :title, 
                    class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors",
                    placeholder: "例: 2024年3月の支援報告書"

              / テンプレート選択
              %div
                = f.label :report_template_id, "レポートテンプレート", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                %p.text-sm.text-slate-500.mb-3
                  AIが生成時に使用するテンプレート形式を選択してください
                = f.select :report_template_id, 
                    options_from_collection_for_select(@available_templates, :id, :name, @support_report.report_template_id),
                    { prompt: "テンプレートを選択してください" },
                    { class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors" }

                / 選択されたテンプレート情報の表示
                - if @support_report.report_template_id && (@selected_template = @available_templates.find { |t| t.id == @support_report.report_template_id })
                  .mt-3.bg-blue-50.dark:bg-blue-900.border.border-blue-200.dark:border-blue-700.rounded-lg.p-4
                    %h4.text-sm.font-medium.text-blue-800.dark:text-blue-200.mb-2
                      📄 選択されたテンプレート: #{@selected_template.name}
                    - if @selected_template.description.present?
                      %p.text-sm.text-blue-700.dark:text-blue-300
                        = @selected_template.description
                    - if @selected_template.is_default?
                      %span.inline-flex.items-center.px-2.py-1.rounded-full.text-xs.font-medium.bg-blue-100.text-blue-800.dark:bg-blue-200.dark:text-blue-900.mt-2
                        デフォルト

                .mt-2
                  = link_to report_templates_path, target: "_blank", class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400" do
                    📄 テンプレート管理画面を開く
                    %span.ml-1 ↗

              / 期間設定
              .grid.grid-cols-1.md:grid-cols-2.gap-4
                %div
                  = f.label :period_start, "開始日", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                  = f.date_field :period_start, 
                      class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

                %div
                  = f.label :period_end, "終了日", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                  = f.date_field :period_end, 
                      class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors"

              / 期間プレビュー
              - if @support_report.period_start && @support_report.period_end
                .bg-blue-50.dark:bg-blue-900.border.border-blue-200.dark:border-blue-700.rounded-lg.p-4
                  %h3.text-sm.font-medium.text-blue-800.dark:text-blue-200.mb-2
                    対象期間の日報データ
                  - activity_count = @character.activities.where(created_at: @support_report.period_start.beginning_of_day..@support_report.period_end.end_of_day).count
                  %p.text-sm.text-blue-700.dark:text-blue-300
                    この期間の日報数: #{activity_count}件
                  - if activity_count == 0
                    %p.text-sm.text-red-600.dark:text-red-400.mt-1
                      ⚠️ この期間には日報データがありません

              / 手動コンテンツ（オプション）
              %div
                = f.label :content, "手動で追記する内容（オプション）", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = f.text_area :content, 
                    rows: 6,
                    class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors",
                    placeholder: "AIが生成する前に追記したい内容があれば入力してください（後から編集も可能です）"

              / 注意事項
              .bg-yellow-50.dark:bg-yellow-900.border.border-yellow-200.dark:border-yellow-700.rounded-lg.p-4
                %h3.text-sm.font-medium.text-yellow-800.dark:text-yellow-200.mb-2
                  📝 生成について
                %ul.text-sm.text-yellow-700.dark:text-yellow-300.space-y-1
                  %li • AIが指定期間の日報データを分析して報告書を生成します
                  %li • 選択されたテンプレートの形式に従って生成されます
                  %li • 生成には数分かかる場合があります
                  %li • 生成後も内容を編集できます

            / アクションボタン
            .px-0.py-4.border-t.border-slate-200.dark:border-slate-600.mt-6
              .flex.justify-between.items-center
                = link_to support_reports_path, 
                    class: "inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do
                  ← キャンセル
                
                .flex.space-x-2
                  - if Rails.env.development?
                    = f.submit "⚡ 即座に生成（デバッグ用）", 
                        name: "sync_generate", 
                        value: "true",
                        class: "inline-flex items-center px-4 py-2 border border-orange-300 text-sm font-medium rounded-md text-orange-700 bg-orange-50 hover:bg-orange-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition-colors"
                  
                  = f.submit "🤖 AI生成で作成", 
                      class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"

  / モバイルナビゲーション（下部固定）
  .lg:hidden.fixed.bottom-0.left-0.right-0.bg-white.border-t.border-slate-200.dark:bg-slate-800.dark:border-slate-700.px-4
    .flex.items-center.justify-around.py-2
      = link_to root_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "🏠"
        %span.text-xs.mt-1 ホーム
      = link_to new_task_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "➕"
        %span.text-xs.mt-1 タスク
      = link_to new_activity_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400", data: { "turbo-frame": "activity_form_modal" } do
        %span.text-lg= "📝"
        %span.text-xs.mt-1 日報
      = link_to activities_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "📖"
        %span.text-xs.mt-1 一覧
      = link_to support_reports_path, class: "flex flex-col items-center py-2 px-1 text-blue-600 dark:text-blue-400" do
        %span.text-lg= "📋"
        %span.text-xs.mt-1 報告書
      %a.flex.flex-col.items-center.py-2.px-1.text-slate-600.dark:text-slate-400{href: "#"}
        %span.text-lg= "⚙️"
        %span.text-xs.mt-1 設定