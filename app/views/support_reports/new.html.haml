/ 支援報告書新規作成ページ
.min-h-screen.bg-slate-50.dark:bg-slate-900
  / メインコンテンツエリア
  .pt-4
    .px-4.sm:px-6.lg:px-8.py-8.pb-24.lg:pb-8
      / 戻るボタン
      .mb-6
        = link_to support_reports_path, class: "inline-flex items-center text-sm text-slate-500 hover:text-slate-700" do
          ← 支援報告書一覧に戻る

      / 検索 + フォーム
      .max-w-5xl.space-y-6
        / 日報検索カード
        .bg-white.dark:bg-slate-800.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700.overflow-hidden
          .px-6.py-6.border-b.border-slate-200.dark:border-slate-700
            %h2.text-xl.font-bold.text-slate-900.dark:text-white
              🔎 日報の絞り込み
            %p.mt-2.text-slate-600.dark:text-slate-400
              利用者・期間・項目・会議名で日報を絞り込んで、対象データを確認してから報告書を生成できます

          = form_with url: new_support_report_path, method: :get, local: true, class: "px-6 py-6" do
            .grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-4.gap-4
              %div
                = label_tag "report_filter_person_keyword", "本文・タイトル内の人物名検索", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = text_field_tag "report_filter[person_keyword]", @person_keyword,
                    placeholder: "例: 群馬太郎",
                    class: "w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white"

              %div
                = label_tag "report_filter_period_start", "開始日", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = date_field_tag "report_filter[period_start]", @filter_period_start,
                    class: "w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white"

              %div
                = label_tag "report_filter_period_end", "終了日", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = date_field_tag "report_filter[period_end]", @filter_period_end,
                    class: "w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white"

              %div
                = label_tag "report_filter_category", "項目", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = select_tag "report_filter[category]",
                    options_for_select(@category_options, @filter_category),
                    class: "w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white"

            .mt-4.flex.justify-end
              = button_tag "絞り込む",
                  type: "submit",
                  class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 transition-colors"

          .px-6.pb-6
            .bg-indigo-50.dark:bg-indigo-900.border.border-indigo-200.dark:border-indigo-700.rounded-lg.p-4
              %p.text-sm.font-medium.text-indigo-800.dark:text-indigo-200
                抽出件数: #{@filtered_activity_count}件
              %p.text-xs.text-indigo-700.dark:text-indigo-300.mt-1
                期間: #{@filter_period_start.strftime('%Y/%m/%d')} 〜 #{@filter_period_end.strftime('%Y/%m/%d')}
              - if @person_keyword.present?
                %p.text-xs.text-indigo-700.dark:text-indigo-300.mt-1
                  人物キーワード: #{@person_keyword}
              - if @character_inference_message.present?
                %p.text-xs.text-amber-700.dark:text-amber-300.mt-1
                  = @character_inference_message

            - if @filtered_activities.any?
              .mt-4.space-y-3
                - @filtered_activities.each do |activity|
                  .border.border-slate-200.dark:border-slate-600.rounded-lg.p-4.bg-slate-50.dark:bg-slate-700
                    .flex.flex-wrap.items-center.gap-2.text-xs.text-slate-500.dark:text-slate-300
                      %span= activity.created_at.strftime('%Y/%m/%d %H:%M')
                      - if activity.category.present?
                        %span.px-2.py-0.5.rounded.bg-slate-200.dark:bg-slate-600.text-slate-700.dark:text-slate-200
                          = activity.category
                      - if activity.visit_start_time.present? && activity.visit_end_time.present?
                        %span
                          = "訪問 #{activity.visit_start_time.strftime('%H:%M')}〜#{activity.visit_end_time.strftime('%H:%M')}"

                    %h3.mt-2.text-sm.font-semibold.text-slate-900.dark:text-white
                      = activity.title.presence || "（タイトルなし）"
                    %p.mt-1.text-sm.text-slate-700.dark:text-slate-200.whitespace-pre-wrap
                      = truncate(activity.content.to_s, length: 180)

                - if @filtered_activity_count > @filtered_activities.size
                  %p.text-xs.text-slate-500.mt-2
                    ※ 表示は先頭#{@filtered_activities.size}件です（全#{@filtered_activity_count}件）
            - else
              .mt-4.border.border-dashed.border-slate-300.dark:border-slate-600.rounded-lg.p-4
                %p.text-sm.text-slate-600.dark:text-slate-300
                  条件に一致する日報がありません。条件を変更して再検索してください。

        .bg-white.dark:bg-slate-800.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700.overflow-hidden
          .px-6.py-6.border-b.border-slate-200.dark:border-slate-700
            %h1.text-2xl.font-bold.text-slate-900.dark:text-white
              📋 支援報告書の新規作成
            %p.mt-2.text-slate-600.dark:text-slate-400
              絞り込み結果を確認した上で、対象利用者の日報から支援報告書を生成します

          = form_with model: @support_report, local: true, class: "px-6 py-6", data: { controller: "generate-from-chat" } do |f|
            = f.hidden_field :character_id, value: @selected_character&.id
            = f.hidden_field :period_start
            = f.hidden_field :period_end
            = hidden_field_tag :selected_activity_ids, @filtered_activity_ids.join(",")
            = hidden_field_tag "report_filter[period_start]", @filter_period_start
            = hidden_field_tag "report_filter[period_end]", @filter_period_end
            = hidden_field_tag "report_filter[person_keyword]", @person_keyword
            = hidden_field_tag "report_filter[category]", @filter_category
            - if @support_report.errors.any?
              .mb-6.bg-red-50.border.border-red-200.rounded-lg.p-4
                %h3.text-sm.font-medium.text-red-800.mb-2
                  入力内容に問題があります：
                %ul.text-sm.text-red-700.space-y-1
                  - @support_report.errors.full_messages.each do |message|
                    %li= message

            .space-y-6
              / タイトル
              %div
                = f.label :title, "タイトル", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = f.text_field :title, 
                    class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors",
                    placeholder: "例: 2024年3月の支援報告書"

              / テンプレート選択
              %div
                = f.label :report_template_id, "レポートテンプレート", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                %p.text-sm.text-slate-500.mb-3
                  AIが生成時に使用するテンプレート形式を選択してください
                = f.select :report_template_id, 
                    options_from_collection_for_select(@available_templates, :id, :name, @support_report.report_template_id),
                    { prompt: "テンプレートを選択してください" },
                    { class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors" }

                .mt-2
                  = link_to report_templates_path, target: "_blank", class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400" do
                    📄 テンプレート管理画面を開く
                    %span.ml-1 ↗

              / 抽出結果サマリー
              .bg-blue-50.dark:bg-blue-900.border.border-blue-200.dark:border-blue-700.rounded-lg.p-4
                %h3.text-sm.font-medium.text-blue-800.dark:text-blue-200.mb-2
                  生成対象サマリー
                %p.text-sm.text-blue-700.dark:text-blue-300
                  - if @person_keyword.present?
                    検索キーワード: #{@person_keyword} / 抽出件数: #{@filtered_activity_count}件
                  - else
                    利用者: #{@selected_character&.name} / 抽出件数: #{@filtered_activity_count}件
                - if @filtered_activity_count == 0
                  %p.text-sm.text-red-600.dark:text-red-400.mt-1
                    ⚠️ 生成対象の日報がありません。上の検索条件を見直してください。

              / 手動コンテンツ（オプション）
              %div
                = f.label :content, "手動で追記する内容（オプション）", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                = f.text_area :content, 
                    rows: 6,
                    class: "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:text-white transition-colors",
                    placeholder: "AIが生成する前に追記したい内容があれば入力してください（後から編集も可能です）"

              / 注意事項
              .bg-yellow-50.dark:bg-yellow-900.border.border-yellow-200.dark:border-yellow-700.rounded-lg.p-4
                %h3.text-sm.font-medium.text-yellow-800.dark:text-yellow-200.mb-2
                  📝 生成について
                %ul.text-sm.text-yellow-700.dark:text-yellow-300.space-y-1
                  %li • AIが指定期間の日報データを分析して報告書を生成します
                  %li • 選択されたテンプレートの形式に従って生成されます
                  %li • 生成には数分かかる場合があります
                  %li • 生成後も内容を編集できます

            / アクションボタン
            .px-0.py-4.border-t.border-slate-200.dark:border-slate-600.mt-6
              .flex.justify-between.items-center
                = link_to support_reports_path, 
                    class: "inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do
                  ← キャンセル
                
                .flex.space-x-2
                  - if Rails.env.development?
                    = button_tag "⚡ 即座に生成（デバッグ用）",
                        type: "submit",
                        name: "sync_generate",
                        value: "true",
                        class: "inline-flex items-center px-4 py-2 border border-orange-300 text-sm font-medium rounded-md text-orange-700 bg-orange-50 hover:bg-orange-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition-colors"
                  
                  = f.submit "🤖 AI生成で作成", 
                      class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"

  / モバイルナビゲーション（下部固定）
  .lg:hidden.fixed.bottom-0.left-0.right-0.bg-white.border-t.border-slate-200.dark:bg-slate-800.dark:border-slate-700.px-4
    .flex.items-center.justify-around.py-2
      = link_to root_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "🏠"
        %span.text-xs.mt-1 ホーム
      = link_to new_task_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "➕"
        %span.text-xs.mt-1 タスク
      = link_to new_activity_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400", data: { "turbo-frame": "activity_form_modal" } do
        %span.text-lg= "📝"
        %span.text-xs.mt-1 日報
      = link_to activities_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "📖"
        %span.text-xs.mt-1 一覧
      = link_to support_reports_path, class: "flex flex-col items-center py-2 px-1 text-blue-600 dark:text-blue-400" do
        %span.text-lg= "📋"
        %span.text-xs.mt-1 報告書
      %a.flex.flex-col.items-center.py-2.px-1.text-slate-600.dark:text-slate-400{href: "#"}
        %span.text-lg= "⚙️"
        %span.text-xs.mt-1 設定