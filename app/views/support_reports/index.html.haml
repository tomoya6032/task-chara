/ 支援報告書一覧ページ
= content_for :page_title, "支援報告書"

.px-4.sm:px-6.lg:px-8.py-8.pb-24.lg:pb-8
  / ヘッダー
  .mb-8
    %h1.text-3xl.font-bold.text-slate-900.dark:text-white
      📋 支援報告書
    %p.text-slate-600.dark:text-slate-400.mt-2
      AI生成による月次支援報告書の管理

  / 統計カード
  .grid.grid-cols-1.md:grid-cols-3.gap-6.mb-8
    .bg-white.dark:bg-slate-800.overflow-hidden.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700
      .px-6.py-4
        .flex.items-center
          .flex-shrink-0
            %span.text-2xl 📋
          .ml-3
            %p.text-sm.font-medium.text-slate-500.dark:text-slate-400 総報告書数
            %p.text-2xl.font-semibold.text-slate-900.dark:text-white
              = @total_count
              %span.text-sm.font-normal.text-slate-500 件

    .bg-white.dark:bg-slate-800.overflow-hidden.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700
      .px-6.py-4
        .flex.items-center
          .flex-shrink-0
            %span.text-2xl 📝
          .ml-3
            %p.text-sm.font-medium.text-slate-500.dark:text-slate-400 ドラフト
            %p.text-2xl.font-semibold.text-slate-900.dark:text-white
              = @draft_count
              %span.text-sm.font-normal.text-slate-500 件

    .bg-white.dark:bg-slate-800.overflow-hidden.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700
      .px-6.py-4
        .flex.items-center
          .flex-shrink-0
            %span.text-2xl ✅
          .ml-3
            %p.text-sm.font-medium.text-slate-500.dark:text-slate-400 完成済み
            %p.text-2xl.font-semibold.text-slate-900.dark:text-white
              = @completed_count
              %span.text-sm.font-normal.text-slate-500 件

  / 新規作成ボタン
  .flex.justify-between.items-center.mb-6
    %div
    = link_to new_support_report_path, 
        class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors shadow-sm" do
      ➕ 新しい報告書

  / 支援報告書一覧
  .bg-white.dark:bg-slate-800.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700.overflow-hidden
    - if @support_reports.any?
      .divide-y.divide-slate-200.dark:divide-slate-700
        - @support_reports.each do |report|
          = link_to support_report_path(report),
              class: "block hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors" do
            .px-6.py-4
              .flex.items-start.justify-between
                .flex-1.min-w-0
                  .flex.items-center.space-x-3.mb-2
                    %span.inline-flex.items-center.px-2.py-1.rounded-full.text-xs.font-medium{
                      class: case report.status
                        when 'draft' then 'bg-gray-100 text-gray-800'
                        when 'generating' then 'bg-yellow-100 text-yellow-800'
                        when 'completed' then 'bg-green-100 text-green-800'
                        when 'error' then 'bg-red-100 text-red-800'
                      end
                    }
                      - case report.status
                        - when 'draft'
                          📝 下書き
                        - when 'generating'
                          ⏳ 生成中
                        - when 'completed'
                          ✅ 完成
                        - when 'error'
                          ❌ エラー

                  %h3.text-lg.font-semibold.text-slate-900.dark:text-white.truncate
                    = strip_tags(report.title)
                  .flex.items-center.space-x-4.text-sm.text-slate-500.dark:text-slate-400
                    %span
                      📅 #{report.period_display}
                    %span
                      🕒 #{report.created_at.strftime('%Y年%m月%d日')} 作成
                    - if report.generated_at
                      %span
                        ✨ #{report.generated_at.strftime('%m/%d %H:%M')} 生成

                  - if report.content.present?
                    %p.text-sm.text-slate-600.dark:text-slate-300.mt-2.line-clamp-2
                      = truncate(strip_tags(report.content), length: 120)

      / ページネーション
      - if @support_reports.respond_to?(:current_page)
        .px-6.py-4.bg-slate-50.dark:bg-slate-900.border-t.border-slate-200.dark:border-slate-700
          .flex.justify-center
            = paginate @support_reports
    
    - else
      / 空の状態
      .text-center.py-12
        .mx-auto.h-24.w-24.text-6xl.mb-4
          📋
        %h3.text-lg.font-medium.text-slate-900.dark:text-white.mb-2
          支援報告書がありません
        %p.text-slate-500.dark:text-slate-400.mb-6
          AIが日報データから自動で支援報告書を生成します
        = link_to new_support_report_path, 
            class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do
          ➕ 最初の報告書を作成