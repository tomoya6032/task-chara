/ 支援報告書詳細ページ
.min-h-screen.bg-slate-50.dark:bg-slate-900
  / デスクトップサイドバー（lg以上で表示）
  .hidden.lg:fixed.lg:inset-y-0.lg:z-50.lg:flex.lg:w-72.lg:flex-col
    .flex.grow.flex-col.gap-y-5.overflow-y-auto.bg-white.dark:bg-slate-800.px-6.border-r.border-slate-200.dark:border-slate-700
      .flex.h-16.shrink-0.items-center
        %h1.text-lg.font-semibold.text-slate-900.dark:text-white
          TaskChara
        %span.ml-2.text-xs.text-slate-500 ✨

      %nav.flex.flex-1.flex-col
        %ul.flex.flex-1.flex-col.gap-y-7{role: "list"}
          %li
            %ul.space-y-1{role: "list"}
              %li
                = link_to dashboard_path, class: "text-slate-400 hover:text-slate-700 hover:bg-slate-50 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold" do
                  📊
                  ダッシュボード
              %li
                = link_to activities_path, class: "text-slate-400 hover:text-slate-700 hover:bg-slate-50 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold" do
                  = "📖"
                  日報一覧
              %li
                = link_to support_reports_path, class: "bg-slate-50 text-slate-700 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold" do
                  = "📋"
                  支援報告書
              %li
                = link_to report_templates_path, class: "text-slate-400 hover:text-slate-700 hover:bg-slate-50 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold" do
                  = "📄"
                  テンプレート管理

  / メインコンテンツエリア
  .lg:pl-72.pt-4
    .px-4.sm:px-6.lg:px-8.py-8
      / 戻るボタン
      .mb-6
        = link_to support_reports_path, class: "inline-flex items-center text-sm text-slate-500 hover:text-slate-700" do
          ← 支援報告書一覧に戻る

      / 支援報告書詳細カード
      .bg-white.dark:bg-slate-800.shadow-xl.rounded-2xl.border.border-slate-200.dark:border-slate-700.overflow-hidden
        .px-6.py-6.border-b.border-slate-200.dark:border-slate-700
          .flex.items-start.justify-between.mb-4
            %div
              %h1.text-2xl.font-bold.text-slate-900.dark:text-white.mb-2
                = @support_report.title
              %p.text-lg.text-slate-600.dark:text-slate-400.mb-3
                = @support_report.period_display
              
              .flex.items-center.space-x-4.text-sm.text-slate-500
                %span
                  = "#{@support_report.created_at.strftime('%Y年%m月%d日')} 作成"
                - if @support_report.generated_at
                  %span
                    = "#{@support_report.generated_at.strftime('%Y年%m月%d日 %H:%M')}生成"
                %span.inline-flex.items-center.px-3.py-1.rounded-full.text-sm.font-medium{
                  class: case @support_report.status
                    when 'draft' then 'bg-gray-100 text-gray-800'
                    when 'generating' then 'bg-yellow-100 text-yellow-800'
                    when 'completed' then 'bg-green-100 text-green-800'
                    when 'error' then 'bg-red-100 text-red-800'
                  end
                }
                  - case @support_report.status
                    - when 'draft'
                      📝 下書き
                    - when 'generating'
                      ⏳ 生成中
                    - when 'completed'
                      ✅ 完成
                    - when 'error'
                      ❌ エラー

        .px-6.py-6
          / 内容表示
          - if @support_report.content.present?
            %div
              %h3.text-lg.font-semibold.text-slate-900.dark:text-white.mb-4
                📋 報告書内容
              .prose.max-w-none.bg-slate-50.dark:bg-slate-700.rounded-lg.p-6
                %div.text-slate-700.dark:text-slate-300.leading-relaxed.whitespace-pre-wrap
                  = @support_report.content
          
          - elsif @support_report.generating?
            / 生成中の状態
            .text-center.py-8
              .animate-spin.rounded-full.h-12.w-12.border-b-2.border-blue-600.mx-auto.mb-4
              %h3.text-lg.font-medium.text-slate-900.dark:text-white.mb-2
                🤖 AIが報告書を生成中です...
              %p.text-slate-500.dark:text-slate-400
                数分お待ちください。完成次第、自動で表示されます。
              %p.text-sm.text-slate-400.mt-2
                ページを閉じても生成は継続されます

          - elsif @support_report.error?
            / エラー状態
            .text-center.py-8
              .text-red-500.text-4xl.mb-4 ❌
              %h3.text-lg.font-medium.text-slate-900.dark:text-white.mb-2
                生成中にエラーが発生しました
              %p.text-slate-500.dark:text-slate-400.mb-4
                APIの制限や一時的な問題が原因の可能性があります
              = button_to generate_support_report_path(@support_report), method: :post,
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do
                🔄 再生成する

          - else
            / 下書き状態
            .text-center.py-8
              .text-slate-400.text-4xl.mb-4 📝
              %h3.text-lg.font-medium.text-slate-900.dark:text-white.mb-2
                下書き状態です
              %p.text-slate-500.dark:text-slate-400.mb-4
                AIによる自動生成を開始してください
              = button_to generate_support_report_path(@support_report), method: :post,
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do
                🤖 AI生成開始

          / 対象期間の日報データプレビュー
          - activities = @support_report.period_activities.limit(5)
          - if activities.any?
            .mt-8.pt-6.border-t.border-slate-200.dark:border-slate-600
              %h3.text-lg.font-semibold.text-slate-900.dark:text-white.mb-4
                📖 対象期間の日報データ（最新5件）
              .space-y-3
                - activities.each do |activity|
                  .bg-slate-50.dark:bg-slate-700.rounded-lg.p-4.border.border-slate-200.dark:border-slate-600
                    .flex.justify-between.items-start.mb-2
                      %h4.font-medium.text-slate-900.dark:text-white
                        = activity.title.present? ? activity.title : "日報"
                      %span.text-xs.text-slate-500
                        = activity.created_at.strftime("%m/%d %H:%M")
                    %p.text-sm.text-slate-600.dark:text-slate-300.line-clamp-2
                      = truncate(activity.content, length: 100)
              - if @support_report.period_activities.count > 5
                %p.text-sm.text-slate-500.text-center.mt-3
                  他#{@support_report.period_activities.count - 5}件

        / アクションボタン
        .px-6.py-4.bg-slate-50.dark:bg-slate-700.border-t.border-slate-200.dark:border-slate-600
          .flex.justify-between.items-center
            = link_to support_reports_path, 
                class: "inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do
              ← 一覧に戻る
            
            .flex.space-x-2
              - unless @support_report.generating?
                = link_to edit_support_report_path(@support_report), 
                    class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors" do
                  📝 編集
                
                - if @support_report.draft? || @support_report.error?
                  = button_to generate_support_report_path(@support_report), method: :post,
                      class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do
                    🤖 AI生成
                
                = button_to support_report_path(@support_report), method: :delete,
                    class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors",
                    data: { confirm: "この支援報告書を削除しますか？" } do
                  🗑️ 削除

  / モバイルナビゲーション（下部固定）
  .lg:hidden.fixed.bottom-0.left-0.right-0.bg-white.border-t.border-slate-200.dark:bg-slate-800.dark:border-slate-700.px-4
    .flex.items-center.justify-around.py-2
      = link_to root_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "🏠"
        %span.text-xs.mt-1 ホーム
      = link_to new_task_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "➕"
        %span.text-xs.mt-1 タスク
      = link_to new_activity_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400", data: { "turbo-frame": "activity_form_modal" } do
        %span.text-lg= "📝"
        %span.text-xs.mt-1 日報
      = link_to activities_path, class: "flex flex-col items-center py-2 px-1 text-slate-600 dark:text-slate-400" do
        %span.text-lg= "📖"
        %span.text-xs.mt-1 一覧
      = link_to support_reports_path, class: "flex flex-col items-center py-2 px-1 text-blue-600 dark:text-blue-400" do
        %span.text-lg= "📋"
        %span.text-xs.mt-1 報告書
      %a.flex.flex-col.items-center.py-2.px-1.text-slate-600.dark:text-slate-400{href: "#"}
        %span.text-lg= "⚙️"
        %span.text-xs.mt-1 設定