= turbo_frame_tag "activity_form_modal" do
  .fixed.inset-0.bg-black.bg-opacity-50.z-50{ data: { controller: "modal" } }
    .fixed.inset-0.flex.items-center.justify-center.p-4.pb-20.lg:pb-4
      .bg-white.rounded-lg.shadow-xl.max-w-lg.w-full{ 
        style: "max-height: calc(100vh - 8rem); overflow-y: auto;",
        data: { modal_target: "content" } 
      }
        .bg-blue-50.px-6.py-4.border-b
          .flex.items-center.justify-between
            %h2.text-xl.font-semibold.text-gray-800
              %i.fas.fa-plus.text-blue-500.mr-2
              日報を投稿
            = link_to root_path, class: "text-gray-500 hover:text-gray-700", data: { turbo_frame: "_top" } do
              %i.fas.fa-times

        .p-6.pb-0
          = form_with model: @activity, url: activities_path, local: false, class: "space-y-4", data: { controller: "slider character-counter image-upload visit-time form-submit websocket", websocket_activity_id_value: "new" } do |form|
            
            / エラー表示
            - if @activity.errors.any?
              .mb-6.bg-red-50.border.border-red-200.rounded-lg.p-4
                %h4.text-red-700.font-medium エラーが発生しました:
                %ul.mt-2.text-sm.text-red-600
                  - @activity.errors.full_messages.each do |message|
                    %li= message
            
            .space-y-4
              .form-group
                = form.label :category, "カテゴリ", class: "block text-sm font-medium text-gray-700 mb-2"
                = form.select :category, [['📚 学習', 'study'], ['💼 仕事', 'work'], ['💪 運動', 'exercise'], ['🎯 目標', 'goal'], ['💭 思考', 'thought'], ['🎉 その他', 'other']], { prompt: 'カテゴリを選択してください' }, { class: "w-full p-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" }

              .space-y-4
                .form-group
                  = form.label :mood_level, "気分", class: "block text-sm font-medium text-gray-700 mb-2"
                  .flex.items-center.space-x-4
                    %span.text-sm.text-gray-500 😔
                    %input{ type: "range", name: "activity[mood_level]", min: "1", max: "5", value: "3", class: "flex-1 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer", data: { slider_target: "mood", action: "input->slider#updateMood" } }
                    %span.text-sm.text-gray-500 😊
                  %span.text-sm.text-gray-600{ data: { slider_target: "moodValue" } } 普通 (3)

                .form-group
                  = form.label :fatigue_level, "疲労度", class: "block text-sm font-medium text-gray-700 mb-2"
                  .flex.items-center.space-x-4
                    %span.text-sm.text-gray-500 😔
                    %input{ type: "range", name: "activity[fatigue_level]", min: "1", max: "5", value: "3", class: "flex-1 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer", data: { slider_target: "fatigue", action: "input->slider#updateFatigue" } }
                    %span.text-sm.text-gray-500 💪
                  %span.text-sm.text-gray-600{ data: { slider_target: "fatigueValue" } } 普通 (3)

              .form-group
                = form.label :title, "訪問相手", class: "block text-sm font-medium text-gray-700 mb-2"
                %span.text-red-500.text-sm *必須
                = form.text_field :title, placeholder: "例：田中太郎さん", class: "w-full p-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500", required: true

              .form-group
                = form.label :visit_start_time, "訪問開始日時", class: "block text-sm font-medium text-gray-700 mb-2"
                = form.datetime_local_field :visit_start_time, class: "w-full p-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500", data: { visit_time_target: "startTime", action: "change->visit-time#syncEndTime change->visit-time#calculateDuration" }

              .form-group
                = form.label :visit_end_time, "訪問終了日時", class: "block text-sm font-medium text-gray-700 mb-2"
                = form.datetime_local_field :visit_end_time, class: "w-full p-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500", data: { visit_time_target: "endTime", action: "change->visit-time#calculateDuration" }

              / 所要時間表示
              .bg-blue-50.border.border-blue-200.rounded-md.p-3.mt-2{ data: { visit_time_target: "duration" }, style: "display: none;" }
                .flex.items-center.space-x-2
                  %i.fas.fa-clock.text-blue-600
                  %span.text-sm.font-medium.text-blue-800 所要時間:
                  %span.text-sm.font-bold.text-blue-900{ data: { visit_time_target: "durationText" } } --

              .form-group
                = form.label :content, "訪問内容", class: "block text-sm font-medium text-gray-700 mb-2"
                %span.text-red-500.text-sm *必須（最低10文字）
                
                / AI入力支援機能
                .mb-4.space-y-3
                  .border.border-blue-200.rounded-lg.p-4.bg-blue-50
                    .flex.items-center.mb-3
                      %i.fas.fa-robot.text-blue-600.mr-2
                      %span.text-sm.font-medium.text-blue-800 AI入力支援
                      %span.text-xs.text-blue-600.ml-2 音声ファイルや画像からテキストを作成できます
                    
                    .grid.grid-cols-1.sm:grid-cols-2.gap-3
                      / 音声ファイルアップロード機能
                      .bg-white.rounded-md.p-3.border{ data: { controller: "voice-uploader", voice_uploader_activity_id_value: "new" } }
                        .flex.items-center.justify-between.mb-2
                          %span.text-sm.font-medium.text-gray-700
                            %i.fas.fa-file-audio.text-purple-500.mr-1
                            音声ファイル
                        .space-y-2
                          %input{ type: "file", accept: "audio/*", class: "hidden", data: { voice_uploader_target: "fileInput", action: "change->voice-uploader#handleFileSelect" } }
                          %button.bg-purple-500.hover:bg-purple-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium{ type: "button", data: { action: "click->voice-uploader#selectFile" } }
                            %i.fas.fa-file-audio.mr-1
                            音声ファイルを選択
                          %div.mt-2{ style: "display: none;", data: { voice_uploader_target: "preview" } }
                            %audio.w-full{ controls: true, data: { voice_uploader_target: "audio" } }
                            %p.text-xs.text-gray-600.mt-1{ data: { voice_uploader_target: "fileName" } }
                          %button.bg-green-500.hover:bg-green-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium{ type: "button", style: "display: none;", data: { voice_uploader_target: "uploadButton", action: "click->voice-uploader#processAudio" } }
                            %i.fas.fa-magic.mr-1
                            文字起こしを実行
                          %button.bg-red-500.hover:bg-red-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium{ type: "button", style: "display: none;", data: { voice_uploader_target: "cancelButton", action: "click->voice-uploader#cancelProcessing" } }
                            %i.fas.fa-times.mr-1
                            キャンセル
                          / テスト用ボタン（開発環境でのみ表示）
                          - if Rails.env.development?
                            %button.bg-yellow-500.hover:bg-yellow-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium.mt-2{ type: "button", data: { action: "click->voice-uploader#testInsert" } }
                            %i.fas.fa-flask.mr-1
                            テスト挿入
                          %div{ data: { voice_uploader_target: "status" } }
                      
                      / 画像OCR機能  
                      .bg-white.rounded-md.p-3.border{ data: { controller: "image-ocr", image_ocr_activity_id_value: "new" } }
                        .flex.items-center.justify-between.mb-2
                          %span.text-sm.font-medium.text-gray-700
                            %i.fas.fa-image.text-blue-500.mr-1
                            画像文字起こし
                        .space-y-2
                          %input{ type: "file", accept: "image/*", class: "hidden", data: { image_ocr_target: "fileInput", action: "change->image-ocr#handleFileSelect" } }
                          %button.bg-blue-500.hover:bg-blue-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium{ type: "button", data: { action: "click->image-ocr#selectFile" } }
                            %i.fas.fa-image.mr-1
                            画像を選択
                          %div.mt-2{ style: "display: none;", data: { image_ocr_target: "preview" } }
                          %button.bg-green-500.hover:bg-green-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium{ type: "button", style: "display: none;", data: { image_ocr_target: "uploadButton", action: "click->image-ocr#processImage" } }
                            %i.fas.fa-magic.mr-1
                            文字起こしを実行
                          %button.bg-red-500.hover:bg-red-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium{ type: "button", style: "display: none;", data: { image_ocr_target: "cancelButton", action: "click->image-ocr#cancelProcessing" } }
                            %i.fas.fa-times.mr-1
                            キャンセル
                          / テスト用ボタン（開発環境でのみ表示）
                          - if Rails.env.development?
                            %button.bg-yellow-500.hover:bg-yellow-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium.mt-2{ type: "button", data: { action: "click->image-ocr#testInsert" } }
                            %i.fas.fa-flask.mr-1
                            テスト挿入
                          - if Rails.env.development?
                            %button.bg-blue-500.hover:bg-blue-600.text-white.px-3.py-2.rounded.text-sm.flex.items-center.justify-center.w-full.font-medium.mt-1{ type: "button", data: { action: "click->websocket#debugTest" } }
                            %i.fas.fa-bug.mr-1
                            デバッグ
                          %div{ data: { image_ocr_target: "status" } }
                
                = form.text_area :content, rows: 6, placeholder: "訪問で行った内容、相談内容、気づいたことなどを記録してください", class: "w-full p-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none", id: "activity_content", data: { character_counter_target: "textarea", action: "input->character-counter#updateCounter" }, required: true, minlength: 10, maxlength: 5000
                .flex.justify-between.items-center.mt-2
                  %span.text-sm.text-gray-600{ data: { character_counter_target: "counter" } } 0文字
                  %span.text-xs.text-gray-400 最大1000文字

              .form-group
                = form.label :image_url, "画像", class: "block text-sm font-medium text-gray-700 mb-2"
                .border-2.border-dashed.border-gray-300.rounded-lg.p-4.text-center.hover:border-gray-400.transition-colors{ data: { image_upload_target: "dropzone" } }
                  %i.fas.fa-cloud-upload-alt.text-3xl.text-gray-400.mb-2
                  %p.text-sm.text-gray-600.mb-2 画像URLを入力するか、ファイルを選択してください
                  = form.url_field :image_url, placeholder: "https://example.com/image.jpg", class: "w-full p-2 border border-gray-300 rounded-md mt-2", data: { image_upload_target: "urlInput", action: "input->image-upload#handleUrlInput" }
                  %p.text-xs.text-gray-500.mt-2 または
                  = form.file_field :image, accept: "image/*", class: "hidden", data: { image_upload_target: "fileInput", action: "change->image-upload#handleFileSelect" }
                  %button.bg-blue-500.hover:bg-blue-700.text-white.font-medium.py-2.px-4.rounded.text-sm.mt-2{ type: "button", data: { action: "click->image-upload#triggerFileSelect" } }
                    ファイルを選択
                .mt-2{ data: { image_upload_target: "preview" }, style: "display: none;" }
                  %img.max-w-full.h-auto.rounded-lg{ data: { image_upload_target: "previewImage" } }
                  .mt-2.text-center
                    %button.text-red-600.hover:text-red-800.text-sm.cursor-pointer{ type: "button", data: { action: "click->image-upload#clearImage" } }
                      画像をクリア

            .flex.flex-col.sm:flex-row.justify-end.space-y-2.sm:space-y-0.sm:space-x-3.pt-4.border-t.bg-gray-50.px-6.py-4.rounded-b-lg
              = link_to root_path, class: "w-full sm:w-auto px-4 py-5 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors text-center", data: { turbo_frame: "_top" } do
                キャンセル
              = form.submit "投稿する", class: "w-full sm:w-auto px-4 py-5 bg-blue-600 border border-transparent rounded-md text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors", data: { "form-submit-target": "submitButton", action: "click->form-submit#handleSubmit" }