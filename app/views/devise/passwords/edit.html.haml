.max-w-md.mx-auto.mt-8.p-6.bg-white.rounded-lg.shadow-md
  %h2.text-2xl.font-bold.mb-6.text-center パスワードの変更

  .bg-blue-50.border.border-blue-200.rounded.p-4.mb-4
    %p.text-sm.text-blue-800.font-semibold.mb-2 📝 パスワードの要件
    %ul.text-sm.text-blue-700.space-y-1.ml-5.list-disc
      %li 最低8文字以上
      %li 大文字を含む（A-Z）
      %li 小文字を含む（a-z）
      %li 数字を含む（0-9）
      %li 記号を含む（!@#$%^&*など）

  = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f|
    = render "devise/shared/error_messages", resource: resource
    = f.hidden_field :reset_password_token

    .field
      = f.label :password, "新しいパスワード", class: "block text-sm font-medium text-gray-700 mb-1"
      = f.password_field :password, autofocus: true, autocomplete: "new-password", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "8文字以上（大文字・小文字・数字・記号を含む）"

    .field
      = f.label :password_confirmation, "新しいパスワード（確認）", class: "block text-sm font-medium text-gray-700 mb-1"
      = f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "確認のため再度入力してください"

    .actions
      = f.submit "パスワードを変更", class: "w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500"

  .mt-6
    = render "devise/shared/links"
