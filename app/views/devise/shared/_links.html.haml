- if controller_name != 'sessions'
  %p.text-center.mt-4
    = link_to "ログイン", new_session_path(resource_name), class: "text-blue-600 hover:text-blue-800 text-sm"

- if devise_mapping.registerable? && controller_name != 'registrations'
  %p.text-center.mt-2
    = link_to "アカウント登録", new_registration_path(resource_name), class: "text-blue-600 hover:text-blue-800 text-sm"

- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations'
  %p.text-center.mt-2
    = link_to "パスワードをお忘れですか？", new_password_path(resource_name), class: "text-blue-600 hover:text-blue-800 text-sm"

- if devise_mapping.confirmable? && controller_name != 'confirmations'
  %p.text-center.mt-2
    = link_to "確認メールが届いていませんか？", new_confirmation_path(resource_name), class: "text-blue-600 hover:text-blue-800 text-sm"

- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks'
  %p.text-center.mt-2
    = link_to "ロック解除メールを再送信", new_unlock_path(resource_name), class: "text-red-600 hover:text-red-800 text-sm font-semibold"

- if devise_mapping.omniauthable?
  - resource_class.omniauth_providers.each do |provider|
    %p.text-center.mt-2
      = button_to "#{OmniAuth::Utils.camelize(provider)}でログイン", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "text-blue-600 hover:text-blue-800 text-sm"
